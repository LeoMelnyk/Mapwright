{
  "name": "mapwright",
  "version": "0.10.0",
  "description": "Dungeon map editor for D&D 5e",
  "author": "Mapwright",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "start": "node --import tsx server.js",
    "dev": "concurrently -n api,vite -c blue,green \"npm run dev:api\" \"npm run dev:vite\"",
    "dev:api": "tsx watch server.js",
    "dev:vite": "vite --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "electron": "node run-electron.cjs",
    "electron:build": "node --preserve-symlinks ./node_modules/electron-builder/out/cli/cli.js --win portable --publish never",
    "electron:build:installer": "node --preserve-symlinks ./node_modules/electron-builder/out/cli/cli.js --win nsis --publish never",
    "electron:build:mac": "node ./node_modules/electron-builder/out/cli/cli.js --mac dmg --publish never",
    "postinstall": "node tools/patch-app-builder.cjs",
    "prepare": "husky || true",
    "download-textures": "node tools/polyhaven/download-polyhaven.js",
    "download-textures:test": "node tools/polyhaven/download-polyhaven.js --limit 5 --dry-run",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write \"src/**/*.ts\" \"tools/**/*.js\" \"test/**/*.{ts,js}\"",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs --check \"src/**/*.ts\" \"tools/**/*.js\" \"test/**/*.{ts,js}\"",
    "lint": "node ./node_modules/eslint/bin/eslint.js src/ tools/",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js src/ tools/ --fix",
    "lint:strict": "node ./node_modules/eslint/bin/eslint.js src/ tools/ --max-warnings 0",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "test:coverage": "node node_modules/vitest/vitest.mjs run --coverage",
    "test:e2e": "node node_modules/vitest/vitest.mjs run --config vitest.e2e.config.js",
    "test:server": "node node_modules/vitest/vitest.mjs run --config vitest.server.config.js",
    "test:render": "node node_modules/vitest/vitest.mjs run --config vitest.render.config.js",
    "test:all": "node node_modules/vitest/vitest.mjs run && node node_modules/vitest/vitest.mjs run --config vitest.render.config.js && node node_modules/vitest/vitest.mjs run --config vitest.server.config.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "d3-delaunay": "^6.0.4",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.2",
    "puppeteer": "^24.2.0",
    "sass": "^1.99.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.90",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.mapwright.editor",
    "productName": "Mapwright",
    "publish": {
      "provider": "github",
      "owner": "LeoMelnyk",
      "repo": "Mapwright"
    },
    "fileAssociations": [
      {
        "ext": "mapwright",
        "name": "Mapwright Dungeon",
        "description": "Mapwright Dungeon Map",
        "mimeType": "application/x-mapwright",
        "role": "Editor"
      }
    ],
    "files": [
      "electron-main.cjs",
      "server.js",
      "src/**/*",
      "examples/**/*",
      "node_modules/**/*",
      "!node_modules/puppeteer/**",
      "!node_modules/puppeteer-core/**",
      "!node_modules/.cache/**"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@napi-rs/**/*.node",
      "node_modules/@napi-rs/**/index.js"
    ],
    "mac": {
      "target": "dmg",
      "icon": "src/MapwrightIcon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "win": {
      "target": "portable",
      "icon": "src/icon.ico",
      "azureSignOptions": {
        "publisherName": "Leo Melnyk",
        "endpoint": "https://eus.codesigning.azure.net/",
        "codeSigningAccountName": "mapwright",
        "certificateProfileName": "mapwright-cert"
      }
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-setup.${ext}"
    }
  },
  "lint-staged": {
    "*.{ts,js,cjs,mjs}": [
      "node ./node_modules/eslint/bin/eslint.js --fix",
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ]
  },
  "optionalDependencies": {
    "@emnapi/core": "*",
    "@emnapi/runtime": "*"
  }
}
