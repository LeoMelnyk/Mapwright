{
  "name": "mapwright",
  "version": "0.1.1",
  "description": "Dungeon map editor for D&D 5e",
  "author": "Mapwright",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "start": "node server.js",
    "electron": "node run-electron.cjs",
    "electron:build": "node --preserve-symlinks ./node_modules/electron-builder/out/cli/cli.js --win portable",
    "postinstall": "node tools/patch-app-builder.cjs",
    "download-textures": "node tools/polyhaven/download-polyhaven.js",
    "download-textures:test": "node tools/polyhaven/download-polyhaven.js --limit 5 --dry-run",
    "lint": "node ./node_modules/eslint/bin/eslint.js src/ tools/",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js src/ tools/ --fix",
    "lint:strict": "node ./node_modules/eslint/bin/eslint.js src/ tools/ --max-warnings 0"
  },
  "devDependencies": {
    "d3-delaunay": "^6.0.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "puppeteer": "^24.2.0"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.90",
    "express": "^5.2.1",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.mapwright.editor",
    "productName": "Mapwright",
    "files": [
      "electron-main.cjs",
      "server.js",
      "src/**/*",
      "examples/**/*",
      "node_modules/**/*",
      "!node_modules/puppeteer/**",
      "!node_modules/puppeteer-core/**",
      "!node_modules/.cache/**"
    ],
    "asar": false,
    "win": {
      "target": "portable",
      "icon": "src/icon.ico",
      "publisherName": "Leo Melnyk",
      "azureSignOptions": {
        "endpoint": "https://eus.codesigning.azure.net/",
        "codeSigningAccountName": "mapwright",
        "certificateProfileName": "mapwright-cert"
      }
    }
  }
}
