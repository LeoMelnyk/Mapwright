# === HITBOX ===
hitbox rect 0.34,0.10 0.32,0.76 z 0-1.8

# Twine hanger at top
line 0.42,0.08 0.58,0.08 stroke #6b4e2e width 2
# Loop knot
circle 0.50,0.08 0.035 fill #4a3820 0.9
# Central braid twine running down
line 0.50,0.12 0.50,0.86 stroke #6b4e2e 0.7 width 1
# Bulb 1 (top left)
ellipse 0.40,0.22 0.10,0.11 fill #f0e8d0 0.92
ellipse 0.40,0.22 0.10,0.11 stroke #8a7850
# Bulb 1 seam
arc 0.40,0.22 0.09 250 290 stroke #b0a078 0.5 width 1
# Bulb 1 green neck top
line 0.40,0.14 0.38,0.10 stroke #6a8a3a width 1
line 0.40,0.14 0.42,0.10 stroke #6a8a3a width 1
