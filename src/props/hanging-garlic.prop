ellipse 0.60,0.30 0.10,0.11 fill #f0e8d0 0.92
ellipse 0.60,0.30 0.10,0.11 stroke #8a7850
arc 0.60,0.30 0.09 250 290 stroke #b0a078 0.5 width 1
line 0.60,0.22 0.58,0.18 stroke #6a8a3a width 1
line 0.60,0.22 0.62,0.18 stroke #6a8a3a width 1
# Bulb 3 (middle left)
ellipse 0.38,0.44 0.10,0.11 fill #ede0c8 0.92
ellipse 0.38,0.44 0.10,0.11 stroke #8a7850
arc 0.38,0.44 0.09 250 290 stroke #b0a078 0.5 width 1
# Bulb 4 (middle right)
