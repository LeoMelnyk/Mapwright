ellipse 0.62,0.52 0.10,0.11 stroke #8a7850
arc 0.62,0.52 0.09 250 290 stroke #b0a078 0.5 width 1
# Bulb 5 (lower left)
ellipse 0.40,0.66 0.10,0.11 fill #ede0c8 0.92
ellipse 0.40,0.66 0.10,0.11 stroke #8a7850
arc 0.40,0.66 0.09 250 290 stroke #b0a078 0.5 width 1
# Bulb 6 (bottom center, largest)
ellipse 0.50,0.78 0.12,0.12 fill #f0e8d0 0.95
ellipse 0.50,0.78 0.12,0.12 stroke #8a7850
