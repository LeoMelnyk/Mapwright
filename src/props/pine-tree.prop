# WSW
poly 0.70,1.25 0.18,1.58 0.75,1.02 fill #0e380a 0.65
poly 0.70,1.25 0.18,1.58 0.75,1.02 stroke #082606 0.35
# West
poly 0.68,1.18 0.10,1.0 0.68,0.82 fill #123c0e 0.7
