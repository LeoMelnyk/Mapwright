name: Pine Tree
category: Terrain
footprint: 2x2
facing: no
shadow: yes
blocks_light: yes
placement: floor
room_types: wilderness, forest, mountain, taiga
typical_count: many
clusters_with: pine-tree, boulder, mushroom
notes: Conifer/evergreen; cluster in groups for forest areas. Compact 1x1 footprint
---
# Hitbox: trunk only, canopy doesn't block at ground level
hitbox circle 1,1.02 0.08

# Footprint 2x2: x 0-2, y 0-2. Center at (1,1).
# Pine tree from above: spiky radial branches like a starburst

# Ground shadow
circle 1,1.05 0.8 fill #0a2008 0.15

# === Outer branch spikes (longest, darkest — 12 pointed branches radiating out) ===
# Each branch is a narrow pointed triangle (poly) from near-center to tip
# North
poly 0.82,0.68 1.0,0.10 1.18,0.68 fill #0e380a 0.7
poly 0.82,0.68 1.0,0.10 1.18,0.68 stroke #082606 0.4
# NNE
poly 1.05,0.68 1.45,0.18 1.25,0.85 fill #123c0e 0.65
