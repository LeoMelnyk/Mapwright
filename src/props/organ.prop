rect 0.3,2.4 2.4,0.3 stroke #333333
# Black keys on keyboard
rect 0.45,2.43 0.09,0.18 fill #222222 0.8
rect 0.63,2.43 0.09,0.18 fill #222222 0.8
rect 0.87,2.43 0.09,0.18 fill #222222 0.8
