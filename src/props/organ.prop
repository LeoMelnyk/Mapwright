rect 0.20,1.60 1.60,0.20 stroke #333333
# Black keys on keyboard
rect 0.30,1.62 0.06,0.12 fill #222222 0.8
rect 0.42,1.62 0.06,0.12 fill #222222 0.8
rect 0.58,1.62 0.06,0.12 fill #222222 0.8
