# Main body/case (dark wood)
rect 0.08,0.08 1.84,1.84 texfill polyhaven/dark_wood 0.85
rect 0.08,0.08 1.84,1.84 stroke #2a1400
# Keyboard strip (front/south edge, seen from above)
