rect 2.25,2.43 0.09,0.18 fill #222222 0.8
rect 2.49,2.43 0.09,0.18 fill #222222 0.8
# Pipe circles (rows of varying diameter, seen from above)
circle 0.45,0.45 0.15 fill #888888 0.5
