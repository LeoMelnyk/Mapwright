line 0.50,0.50 0.50,0.88 stroke #a060c0 width 2
line 0.50,0.50 0.28,0.80 stroke #b070d0 width 2
line 0.50,0.50 0.14,0.58 stroke #a060c0 width 2
line 0.50,0.50 0.14,0.42 stroke #b070d0 width 2
line 0.50,0.50 0.28,0.20 stroke #a060c0 width 2
line 0.50,0.50 0.68,0.12 stroke #60c0e0 width 2
line 0.50,0.50 0.32,0.12 stroke #60c0e0 width 2
