rect 0.42,0.30 0.16,2.40 texfill polyhaven/metal_plate 0.7
rect 0.42,0.30 0.16,2.40 stroke #444444 width 2

# Blade sheen highlight down center
line 0.50,0.32 0.50,2.68 stroke #ddddee 0.55 width 1
line 0.48,0.32 0.48,2.68 stroke #bbbbcc 0.4 width 1

# === Teeth along west edge (pointing outward) ===
