circle 0.80,0.14 0.06 texfill polyhaven/dark_wood 0.5
circle 0.80,0.14 0.06 stroke #1a0800

# Handle binding (iron collar attaching bar to blade tang)
rect 0.40,0.18 0.20,0.08 fill #555555 0.95
rect 0.40,0.18 0.20,0.08 stroke #222222 width 2
# Rivets
circle 0.44,0.22 0.012 fill #111111 0.9
circle 0.56,0.22 0.012 fill #111111 0.9

# Stub of blade emerging south from collar
rect 0.46,0.26 0.08,0.04 fill #8899aa 0.95
rect 0.46,0.26 0.08,0.04 stroke #222222

# === Main blade (long thin steel running N-S) ===
