name: Pit Saw
category: Tools
footprint: 3x1
facing: yes
shadow: yes
blocks_light: no
height: 0.2
placement: floor
room_types: mill-lumber, lumberyard, carpentry, shipyard, sawmill
typical_count: single
clusters_with: log-round, wood-chip-pile, sawdust-pile, sawhorse, workbench
notes: Long two-handed pit saw for splitting logs into planks — steel blade with toothed edge running full length, wooden handles at both ends. Laid across the floor; north-south orientation.
---
# === HITBOX ===
selection rect 0.18,0.08 0.64,2.84

# footprint 3x1: x range 0-1, y range 0-3 (very long)

# === Subtle ground shadow ===
ellipse 0.50,1.50 0.18,1.40 fill #1a1008 0.15

# === North handle (tiller — big T-shape with two grips) ===
# Handle bar (cross piece, east-west)
rect 0.18,0.10 0.64,0.08 fill #8b6914 0.95
rect 0.18,0.10 0.64,0.08 texfill polyhaven/dark_wood 0.5
rect 0.18,0.10 0.64,0.08 stroke #2a1400 width 2

# Grip ends (rounded caps)
circle 0.20,0.14 0.06 fill #5c3a1e 0.95
circle 0.20,0.14 0.06 texfill polyhaven/dark_wood 0.5
circle 0.20,0.14 0.06 stroke #1a0800
