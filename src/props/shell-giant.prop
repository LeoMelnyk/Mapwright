# Footprint 2x2: x 0-2, y 0-2.
# Outer shell — lower half (southern half of the opened clam)
poly 0.20,1.00 0.40,1.60 0.80,1.88 1.20,1.88 1.60,1.60 1.80,1.00 1.70,1.10 1.45,1.72 1.00,1.84 0.55,1.72 0.30,1.10 fill #d8c8b0 0.9
