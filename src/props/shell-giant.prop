poly 0.30,0.90 0.55,0.28 1.00,0.16 1.45,0.28 1.70,0.90 1.55,0.85 1.00,0.25 0.45,0.85 stroke #8a7a6a
# Ridged fan pattern — lower half
line 1.00,1.00 0.25,1.15 stroke #a09080 width 1
line 1.00,1.00 0.45,1.55 stroke #a09080 width 1
line 1.00,1.00 0.70,1.78 stroke #a09080 width 1
