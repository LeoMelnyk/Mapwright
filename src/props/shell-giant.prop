line 1.00,1.00 1.55,1.55 stroke #a09080 width 1
line 1.00,1.00 1.75,1.15 stroke #a09080 width 1
# Ridged fan pattern — upper half
line 1.00,1.00 0.25,0.85 stroke #a09080 width 1
line 1.00,1.00 0.45,0.45 stroke #a09080 width 1
line 1.00,1.00 0.70,0.22 stroke #a09080 width 1
line 1.00,1.00 1.00,0.15 stroke #a09080 width 1
line 1.00,1.00 1.30,0.22 stroke #a09080 width 1
line 1.00,1.00 1.55,0.45 stroke #a09080 width 1
line 1.00,1.00 1.75,0.85 stroke #a09080 width 1
