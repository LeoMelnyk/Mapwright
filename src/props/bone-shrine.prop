name: Bone Shrine
category: Religious
footprint: 2x1
facing: yes
shadow: no
blocks_light: yes
height: 4
placement: wall
room_types: crypt, ossuary, necromancer-lair
typical_count: few
clusters_with: bone-pile, burial-urn, candle-cluster
notes: Macabre devotional site; place against walls
---
# footprint 2x1: x range 0-1, y range 0-2
# Top-down: stone altar slab with bones arranged ritualistically

# Stone base slab
rect 0.05,0.1 0.9,1.8 texfill polyhaven/stone_wall 0.6
rect 0.05,0.1 0.9,1.8 stroke #555555

# Dark ritual stain on stone (subtle circle)
circle 0.5,1.0 0.35 fill #1a0a0a 0.15

# Femur bones arranged in an X pattern around the skull
# Top-left to bottom-right
rect 0.12,0.35 0.55,0.06 fill #c8b898 0.7
circle 0.15,0.38 0.04 fill #d4c4a8 0.7
circle 0.64,0.38 0.04 fill #d4c4a8 0.7
# Bottom-left to top-right (crossing)
rect 0.12,0.5 0.55,0.06 fill #d4c4a8 0.65
circle 0.15,0.53 0.04 fill #e8dcc8 0.65
circle 0.64,0.53 0.04 fill #e8dcc8 0.65

# Lower bones (another X below skull)
rect 0.22,1.4 0.55,0.06 fill #c8b898 0.65
circle 0.25,1.43 0.04 fill #d4c4a8 0.65
circle 0.74,1.43 0.04 fill #d4c4a8 0.65
