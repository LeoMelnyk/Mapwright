circle 0.15,0.73 0.04 fill #d4c4a8 0.6
circle 0.15,1.17 0.04 fill #d4c4a8 0.6
rect 0.82,0.7 0.06,0.5 fill #c8b898 0.6
circle 0.85,0.73 0.04 fill #d4c4a8 0.6
circle 0.85,1.17 0.04 fill #d4c4a8 0.6

# Small skulls at the four corners of the arrangement
