ellipse 0.74,0.48 0.08,0.06 stroke #4a2810

# Ears (tiny triangles on head)
poly 0.76,0.42 0.79,0.40 0.78,0.44 fill #6a4820 0.9
poly 0.80,0.42 0.82,0.40 0.80,0.44 fill #6a4820 0.9

# === Tail (small carved stub extending west) ===
poly 0.28,0.48 0.22,0.46 0.20,0.50 0.22,0.54 0.28,0.52 fill #6a4820 0.95
poly 0.28,0.48 0.22,0.46 0.20,0.50 0.22,0.54 0.28,0.52 stroke #2a1400

# === Mane (darker brown stripe along the neck/back) ===
line 0.58,0.46 0.74,0.46 stroke #4a2810 width 2
