# footprint 1x1: x 0-1, y 0-1
# Top-down: small carved wooden horse toy with wheels on a tiny platform, seen from directly above

# === Shadow under toy ===
ellipse 0.50,0.58 0.28,0.08 fill #000000 0.22

# === Wooden platform (base with wheels) ===
rect 0.22,0.42 0.56,0.22 texfill polyhaven/dark_wood 0.88
rect 0.22,0.42 0.56,0.22 stroke #2a1400

# === Four wheels (seen as small discs at corners of platform) ===
circle 0.26,0.44 0.05 fill #5c3a1e 0.95
circle 0.26,0.44 0.05 stroke #1a0800
circle 0.26,0.44 0.015 fill #1a0800 0.95

circle 0.74,0.44 0.05 fill #5c3a1e 0.95
circle 0.74,0.44 0.05 stroke #1a0800
circle 0.74,0.44 0.015 fill #1a0800 0.95

