circle 0.74,0.62 0.05 fill #5c3a1e 0.95
circle 0.74,0.62 0.05 stroke #1a0800
circle 0.74,0.62 0.015 fill #1a0800 0.95

# === Horse body silhouette on top — from above, mostly a rounded rectangular back ===
# Body (elongated oval running east-west)
ellipse 0.50,0.50 0.22,0.09 fill #a8824a 0.95
ellipse 0.50,0.50 0.22,0.09 stroke #4a2810 width 1

# === Horse head (small bump extending east) ===
