name: Hanging Vine
category: Decorative
footprint: 1x2
facing: yes
shadow: no
blocks_light: no
height: 3.0
placement: center
room_types: ancient-ruin-overgrown, jungle, overgrown-ruin, forest, grotto, fey-glade, cave
typical_count: few
clusters_with: tree, vine, moss-patch, ruin-column, fallen-pillar
notes: Hanging vines suspended from overhead. Top-down view shows vertical strand shadows with small leaves visible — not floor plants, but vines hanging DOWN from above.
---
# footprint 1x2: x 0-2, y 0-1
# Overhead prop — no shadow, no light-block

# === Faint shadow lines on ground where vines hang ===
line 0.30,0.20 0.34,0.80 stroke #1a1a08 0.15 width 4
line 0.70,0.20 0.66,0.80 stroke #1a1a08 0.15 width 4
line 1.10,0.20 1.14,0.80 stroke #1a1a08 0.15 width 4
line 1.50,0.20 1.46,0.80 stroke #1a1a08 0.15 width 4
line 1.80,0.20 1.84,0.80 stroke #1a1a08 0.15 width 4

# === Main vine strands (bezier curves, slightly swaying) ===
# Strand 1 (west)
bezier 0.30,0.08 0.28,0.30 0.36,0.55 0.34,0.88 stroke #3a5a1e width 3
bezier 0.30,0.08 0.28,0.30 0.36,0.55 0.34,0.88 stroke #1a3a08 0.7 width 1

# Strand 2
bezier 0.70,0.08 0.72,0.30 0.64,0.55 0.66,0.88 stroke #3a5a1e width 3
bezier 0.70,0.08 0.72,0.30 0.64,0.55 0.66,0.88 stroke #1a3a08 0.7 width 1

# Strand 3
bezier 1.10,0.08 1.08,0.30 1.16,0.55 1.14,0.88 stroke #2d5a1e width 3
bezier 1.10,0.08 1.08,0.30 1.16,0.55 1.14,0.88 stroke #1a3a08 0.7 width 1

# Strand 4
bezier 1.50,0.08 1.52,0.30 1.44,0.55 1.46,0.88 stroke #3a5a1e width 3
bezier 1.50,0.08 1.52,0.30 1.44,0.55 1.46,0.88 stroke #1a3a08 0.7 width 1

# Strand 5 (east)
bezier 1.80,0.08 1.82,0.30 1.86,0.55 1.84,0.88 stroke #2d5a1e width 3
bezier 1.80,0.08 1.82,0.30 1.86,0.55 1.84,0.88 stroke #1a3a08 0.7 width 1

# === Small leaves along the vines (visible from above as oval blotches) ===
