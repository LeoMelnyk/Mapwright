line 0.62,0.42 0.70,0.38 stroke #777777 width 2
line 0.28,0.50 0.36,0.54 stroke #888888 width 2
line 0.34,0.58 0.44,0.56 stroke #777777 width 2
line 0.42,0.60 0.50,0.64 stroke #888888 width 2
line 0.52,0.58 0.60,0.62 stroke #777777 width 2
line 0.60,0.58 0.68,0.54 stroke #888888 width 2
line 0.40,0.50 0.48,0.46 stroke #888888 width 2
line 0.54,0.36 0.62,0.34 stroke #777777 width 2
line 0.20,0.48 0.28,0.46 stroke #888888 width 2
line 0.68,0.48 0.74,0.50 stroke #777777 width 2
line 0.36,0.66 0.44,0.68 stroke #888888 width 2
line 0.58,0.66 0.66,0.64 stroke #777777 width 2

# === Nail head caps (small bright metallic dots at one end of each shaft) ===
circle 0.26,0.38 0.014 fill #aabbcc 0.75
circle 0.38,0.48 0.014 fill #aabbcc 0.7
circle 0.44,0.40 0.012 fill #aabbcc 0.75
circle 0.54,0.42 0.014 fill #aabbcc 0.7
circle 0.56,0.50 0.012 fill #aabbcc 0.7
circle 0.62,0.52 0.014 fill #aabbcc 0.75
circle 0.70,0.38 0.014 fill #aabbcc 0.7
circle 0.36,0.54 0.012 fill #aabbcc 0.7
circle 0.44,0.56 0.014 fill #aabbcc 0.75
circle 0.50,0.64 0.012 fill #aabbcc 0.7
circle 0.60,0.62 0.014 fill #aabbcc 0.7
circle 0.68,0.54 0.012 fill #aabbcc 0.7
circle 0.48,0.46 0.012 fill #aabbcc 0.7
circle 0.62,0.34 0.014 fill #aabbcc 0.7
circle 0.28,0.46 0.012 fill #aabbcc 0.65
circle 0.74,0.50 0.012 fill #aabbcc 0.65
circle 0.44,0.68 0.012 fill #aabbcc 0.65
circle 0.66,0.64 0.012 fill #aabbcc 0.65

# === Rust streaks on a couple nails ===
line 0.44,0.40 0.50,0.42 stroke #6a3818 0.55 width 1
line 0.56,0.50 0.60,0.52 stroke #6a3818 0.5 width 1

# === A few outlier nails at edges ===
line 0.14,0.38 0.20,0.42 stroke #777777 width 2
circle 0.14,0.38 0.012 fill #aabbcc 0.6
