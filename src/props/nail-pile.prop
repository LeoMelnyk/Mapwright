name: Nail Pile
category: Workshop
footprint: 1x1
facing: no
shadow: no
blocks_light: no
height: 0.05
placement: floor
room_types: general-workshop, forge, smithy, shop-general, cooperage, mill-lumber, construction
typical_count: few
clusters_with: nails-crate, hammer, workbench, tool-scatter, wood-shavings
notes: Loose scatter of iron nails on the floor — spilled from a bucket or crate. Small pile, not contained.
---
# === HITBOX ===
selection circle 0.5,0.5 0.32

# footprint 1x1: x range 0-1, y range 0-1
# Top-down: dense scatter of small iron nails at random angles on the floor

# === Subtle ground darken under the pile ===
ellipse 0.50,0.52 0.34,0.26 fill #1a1408 0.2
ellipse 0.50,0.52 0.22,0.18 fill #1a1408 0.3

# === Nail shafts — small metallic lines at various angles ===
line 0.26,0.38 0.34,0.36 stroke #777777 width 2
line 0.30,0.44 0.38,0.48 stroke #888888 width 2
line 0.38,0.36 0.44,0.40 stroke #777777 width 2
line 0.44,0.44 0.54,0.42 stroke #888888 width 2
