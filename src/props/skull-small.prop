arc 0.64,0.56 0.06 90 270 stroke #6a5040 0.65 width 1
# Hairline cracks across cranium (age)
bezier 0.34,0.36 0.40,0.34 0.48,0.36 0.54,0.32 stroke #4a3828 0.6 width 1
line 0.56,0.44 0.62,0.40 stroke #4a3828 0.55 width 1
