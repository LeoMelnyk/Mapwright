ellipse 0.56,0.38 0.10,0.08 fill #c8a868 0.3
# Eye sockets (two dark hollows)
ellipse 0.42,0.48 0.055,0.065 fill #1a1008 0.95
ellipse 0.42,0.48 0.055,0.065 stroke #4a3828
ellipse 0.58,0.48 0.055,0.065 fill #1a1008 0.95
ellipse 0.58,0.48 0.055,0.065 stroke #4a3828
