poly 0.42,0.60 0.58,0.60 0.56,0.74 0.50,0.80 0.44,0.74 stroke #6a5040
# Snout suture / central seam
line 0.50,0.60 0.50,0.78 stroke #6a5040 0.6 width 1
# Nasal cavity (dark triangular opening at snout tip)
poly 0.48,0.66 0.52,0.66 0.50,0.74 fill #1a1008 0.9
poly 0.48,0.66 0.52,0.66 0.50,0.74 stroke #4a3828
# Small teeth ridge along lower snout edge
line 0.45,0.78 0.47,0.80 stroke #6a5040 width 1
line 0.49,0.79 0.51,0.81 stroke #6a5040 width 1
line 0.53,0.78 0.55,0.80 stroke #6a5040 width 1
# Cheekbone arches (side ridges between eye and jaw)
