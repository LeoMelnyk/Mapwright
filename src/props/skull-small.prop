# Cranium dome texture wash
ellipse 0.50,0.42 0.22,0.22 texfill polyhaven/granite_tile 0.25
# Cranial suture (zig-zag seam across top)
line 0.42,0.30 0.46,0.34 stroke #6a5040 0.7 width 1
line 0.46,0.34 0.50,0.30 stroke #6a5040 0.7 width 1
line 0.50,0.30 0.54,0.34 stroke #6a5040 0.7 width 1
line 0.54,0.34 0.58,0.30 stroke #6a5040 0.7 width 1
