# Written lines (ink strokes)
line 0.30,0.40 0.64,0.40 stroke #2a1400 0.7
line 0.30,0.46 0.68,0.46 stroke #2a1400 0.7
line 0.30,0.52 0.58,0.52 stroke #2a1400 0.6
line 0.30,0.58 0.62,0.58 stroke #2a1400 0.6
