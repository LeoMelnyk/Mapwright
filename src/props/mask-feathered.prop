poly 0.74,0.42 0.84,0.08 0.88,0.10 0.78,0.44 stroke #5c3a1e width 1

# Feather barb lines (thin radial hairs)
line 0.80,0.30 0.82,0.25 stroke #3a0000 0.7 width 1
line 0.82,0.32 0.86,0.28 stroke #3a0000 0.7 width 1
line 0.86,0.20 0.90,0.18 stroke #5a3a00 0.7 width 1
line 0.80,0.16 0.84,0.12 stroke #5c3a1e 0.7 width 1

# Mask body (eye-shaped, black velvet)
poly 0.14,0.44 0.22,0.38 0.42,0.38 0.50,0.44 0.58,0.38 0.78,0.38 0.86,0.44 0.82,0.62 0.62,0.68 0.50,0.60 0.38,0.68 0.18,0.62 fill #1a0808 0.95
