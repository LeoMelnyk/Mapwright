poly 0.14,0.44 0.22,0.38 0.42,0.38 0.50,0.44 0.58,0.38 0.78,0.38 0.86,0.44 0.82,0.62 0.62,0.68 0.50,0.60 0.38,0.68 0.18,0.62 stroke #000000 width 2

# Gold trim along outer edge of mask
poly 0.16,0.46 0.24,0.40 0.40,0.40 0.50,0.46 0.60,0.40 0.76,0.40 0.84,0.46 0.80,0.60 0.62,0.66 0.50,0.58 0.38,0.66 0.20,0.60 stroke #daa520 0.8 width 1

# Left eyehole
