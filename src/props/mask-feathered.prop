# === HITBOX ===
selection rect 0.14,0.36 0.72,0.36

# Feather plume extending NE (cluster of tall feathers)
poly 0.70,0.40 0.86,0.18 0.88,0.22 0.74,0.44 fill #8b0000 0.9
