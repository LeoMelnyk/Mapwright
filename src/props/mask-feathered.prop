ellipse 0.30,0.50 0.08,0.06 stroke #daa520 0.9 width 1

# Right eyehole
ellipse 0.70,0.50 0.08,0.06 fill #000000 0.98
ellipse 0.70,0.50 0.08,0.06 stroke #daa520 0.9 width 1

# Gold filigree swirls above each eye
arc 0.30,0.44 0.10 180 340 stroke #daa520 0.75 width 1
arc 0.70,0.44 0.10 200 360 stroke #daa520 0.75 width 1

# Central nose bridge detail (gilt)
circle 0.50,0.50 0.025 fill #daa520 0.85
circle 0.50,0.50 0.025 stroke #5a3a00 width 1

# Tie ribbons trailing SW
qbezier 0.16,0.60 0.12,0.70 0.06,0.76 stroke #8b0000 0.85 width 2
