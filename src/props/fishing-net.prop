line 0.85,0.22 0.45,1.65 stroke #8b7355
line 0.58,0.38 0.3,1.5 stroke #8b7355

# Horizontal lines (trimmed to circle width at each y)
line 0.35,0.55 1.65,0.55 stroke #8b7355
line 0.25,0.85 1.75,0.85 stroke #8b7355
line 0.25,1.15 1.75,1.15 stroke #8b7355
line 0.35,1.45 1.65,1.45 stroke #8b7355

# Knots at intersections
# Row 1
circle 0.55,0.55 0.03 fill #6b4e2e
