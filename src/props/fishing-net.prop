name: Fishing Net
category: Nautical
footprint: 2x2
facing: no
shadow: no
blocks_light: no
placement: floor
room_types: dock, harbor, fishing-village
typical_count: few
clusters_with: fish-drying-rack, lobster-trap
notes: Spread on ground near docks or draped over crates
---
# footprint 2x2: x range 0-2, y range 0-2
# Circular net spread on the ground with diamond mesh
# All mesh lines stay within the circle (radius 0.85, center 1.0,1.0)

# Circular border rope
circle 1.0,1.0 0.85 stroke #6b4e2e

# Diamond mesh — diagonal lines (kept well inside circle)
# Top-left to bottom-right
line 0.4,0.42 0.7,1.58 stroke #8b7355
line 0.6,0.28 1.0,1.72 stroke #8b7355
line 0.85,0.22 1.3,1.78 stroke #8b7355
line 1.15,0.22 1.55,1.65 stroke #8b7355
line 1.42,0.38 1.7,1.5 stroke #8b7355
# Top-right to bottom-left
line 1.6,0.42 1.3,1.58 stroke #8b7355
