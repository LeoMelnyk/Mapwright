ellipse 0.46,0.86 0.03,0.045 stroke #222222 width 1
# Link 5
ellipse 0.52,1.00 0.045,0.03 fill #666666 0.9
ellipse 0.52,1.00 0.045,0.03 stroke #222222 width 1
# Link 6 (chain starts curving)
ellipse 0.48,1.14 0.03,0.045 fill #555555 0.9
ellipse 0.48,1.14 0.03,0.045 stroke #222222 width 1
# Link 7
ellipse 0.54,1.28 0.045,0.03 fill #666666 0.9
ellipse 0.54,1.28 0.045,0.03 stroke #222222 width 1
# Link 8
ellipse 0.46,1.42 0.03,0.045 fill #555555 0.9
ellipse 0.46,1.42 0.03,0.045 stroke #222222 width 1
# Link 9 (curving east slightly)
ellipse 0.52,1.54 0.045,0.03 fill #666666 0.9
ellipse 0.52,1.54 0.045,0.03 stroke #222222 width 1

# Chain shadow/scuff on ground
ellipse 0.50,1.00 0.08,0.50 fill #1a1008 0.15

# === Leather collar (south end, open/unbuckled, lying flat) ===
# Main collar strap (curved ring shape)
ering 0.55,1.70 0.16,0.12 0.11,0.08 fill #5c3a1e 0.9
ering 0.55,1.70 0.16,0.12 0.11,0.08 stroke #2a1400 width 2

# Collar buckle (metal D-ring)
rect 0.64,1.66 0.05,0.08 fill #666666 0.9
rect 0.64,1.66 0.05,0.08 stroke #222222 width 1
circle 0.66,1.70 0.02 fill #333333 0.9

# Collar studs (metal decorations)
