ellipse 0.52,0.44 0.045,0.03 fill #666666 0.9
ellipse 0.52,0.44 0.045,0.03 stroke #222222 width 1
# Link 2
ellipse 0.48,0.58 0.03,0.045 fill #555555 0.9
ellipse 0.48,0.58 0.03,0.045 stroke #222222 width 1
