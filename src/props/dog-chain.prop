name: Dog Chain
category: Misc
footprint: 2x1
facing: yes
shadow: no
blocks_light: no
height: 0.3
placement: corner
room_types: lumberyard, stable, yard, farmhouse-exterior, guardhouse
typical_count: single
clusters_with: post, kennel, bone-pile, water-trough
notes: Heavy iron chain with empty leather collar, anchored to a wooden post. The dog is absent — chain lies slack on the ground.
---
# footprint 2x1: x 0-1, y 0-2
# === HITBOX ===
selection circle 0.50,0.30 0.20
selection rect 0.30,0.50 0.40,1.40

# === Wooden post (anchor, north end) ===
circle 0.50,0.30 0.18 texfill polyhaven/dark_wood 0.85
circle 0.50,0.30 0.18 fill #3a1f00 0.4
circle 0.50,0.30 0.18 stroke #1a1008 width 2

# Post wood grain (concentric rings)
circle 0.50,0.30 0.14 stroke #2a1400 0.7 width 1
circle 0.50,0.30 0.10 stroke #2a1400 0.6 width 1
circle 0.50,0.30 0.06 stroke #2a1400 0.6 width 1
circle 0.50,0.30 0.012 fill #1a1008 0.8

# === Iron ring bolted to top of post ===
ring 0.50,0.30 0.06 0.035 fill #444444 0.9
ring 0.50,0.30 0.06 0.035 stroke #222222 width 1

# Bolt head (square plate)
rect 0.44,0.22 0.04,0.04 fill #555555 0.9
rect 0.44,0.22 0.04,0.04 stroke #222222

# === Chain (heavy links, trailing south along the ground) ===
