# Dirt and impact splatter around the shaft
ellipse 0.50,0.52 0.24,0.12 fill #3a2818 0.55
ellipse 0.50,0.52 0.24,0.12 stroke #1a1008 0.5
# Scattered dirt clods
circle 0.28,0.52 0.024 fill #2a1a0a 0.7
