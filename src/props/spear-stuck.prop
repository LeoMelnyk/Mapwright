circle 0.36,0.62 0.018 fill #3a2818 0.6
circle 0.64,0.44 0.018 fill #3a2818 0.6
# Impact hole around the spear butt
circle 0.50,0.52 0.05 fill #0a0604 0.95
# Short visible stub of the shaft (the rest is buried)
circle 0.50,0.52 0.04 fill #5c3a1e 0.95
circle 0.50,0.52 0.04 texfill polyhaven/dark_wood 0.5
circle 0.50,0.52 0.04 stroke #2a1400 width 1
# Leather binding wrap around the shaft just above the ground
circle 0.50,0.40 0.055 fill #4a2800 0.95
circle 0.50,0.40 0.055 stroke #1a0a00 width 1
line 0.46,0.38 0.54,0.42 stroke #1a0a00 0.7 width 1
line 0.46,0.42 0.54,0.38 stroke #1a0a00 0.7 width 1
# Shaft continues upward (thin rectangle poking out toward the viewer)
rect 0.47,0.24 0.06,0.16 fill #5c3a1e 0.95
rect 0.47,0.24 0.06,0.16 texfill polyhaven/dark_wood 0.4
rect 0.47,0.24 0.06,0.16 stroke #2a1400 width 1
# Feather tuft bound at the top (tribal decoration fanning outward)
