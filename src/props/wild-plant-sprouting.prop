poly 0.70,0.30 0.64,0.26 0.66,0.22 0.72,0.24 fill #4a7a3a 0.9
poly 0.70,0.30 0.64,0.26 0.66,0.22 0.72,0.24 stroke #2a4a18
poly 0.74,0.28 0.80,0.24 0.80,0.20 0.74,0.22 fill #3a6a2a 0.9
poly 0.74,0.28 0.80,0.24 0.80,0.20 0.74,0.22 stroke #2a4a18
# Tiny white flower cluster at top
circle 0.72,0.16 0.018 fill #e8e4d8 0.95
circle 0.74,0.18 0.014 fill #f0ecd8 0.9

# === Creeping vine (diagonal across center) ===
bezier 0.20,0.56 0.38,0.50 0.56,0.62 0.76,0.58 stroke #3a6a2a width 2
# Vine leaves along the curve
poly 0.34,0.52 0.38,0.48 0.42,0.52 0.38,0.56 fill #4a7a3a 0.85
poly 0.34,0.52 0.38,0.48 0.42,0.52 0.38,0.56 stroke #2a4a18
