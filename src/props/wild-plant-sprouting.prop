poly 0.56,0.58 0.60,0.54 0.64,0.60 0.60,0.64 stroke #2a4a18
# Tiny yellow flower on vine
circle 0.44,0.50 0.016 fill #ffd730 0.9
circle 0.44,0.50 0.016 stroke #8a6a08

# === Grass tuft 2 (S) — thicker cluster ===
line 0.42,0.86 0.36,0.72 stroke #3a6a2a width 2
line 0.42,0.86 0.42,0.70 stroke #4a7a3a width 2
line 0.42,0.86 0.48,0.72 stroke #3a6a2a width 2
line 0.42,0.86 0.52,0.76 stroke #4a7a3a width 1
line 0.42,0.86 0.32,0.76 stroke #3a6a2a width 1

