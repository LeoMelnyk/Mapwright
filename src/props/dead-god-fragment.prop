# Weathered inner mass (marble-like worn surface)
poly 0.95,0.3 1.4,0.36 1.64,0.58 1.72,0.95 1.66,1.35 1.48,1.6 1.1,1.72 0.7,1.62 0.4,1.42 0.32,1.05 0.36,0.68 0.58,0.4 fill #8a7a90 0.6

# Massive clenched eye (central orb, staring)
circle 1.0,1.0 0.26 fill #4a3a80 0.75
circle 1.0,1.0 0.26 stroke #2a1850 width 2
# Pupil slit
ellipse 1.0,1.0 0.06,0.18 fill #1a0828 0.9
# Iris glow
circle 1.0,1.0 0.14 stroke #a080ff width 1
circle 1.0,1.0 0.08 stroke #e0e0ff width 1

# Cosmic fractures — radiating cracks with gold leaf
bezier 1.0,0.26 0.9,0.5 1.1,0.72 0.95,0.92 stroke #daa520 width 2
