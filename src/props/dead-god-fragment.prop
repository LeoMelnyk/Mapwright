bezier 1.1,1.1 1.35,1.2 1.6,1.5 1.78,1.72 stroke #daa520 width 2
bezier 1.4,0.32 1.3,0.6 1.2,0.8 1.08,0.88 stroke #daa520 width 1

# Glowing violet leak from fractures
bezier 1.0,0.26 0.9,0.5 1.1,0.72 0.95,0.92 stroke #a080ff width 1
