# footprint 1x1: x range 0-1, y range 0-1

# === Wooden hoop (NW) ===
ring 0.28,0.30 0.18,0.12 fill #8b6914 0.9
ring 0.28,0.30 0.18,0.12 stroke #3a1f00
# Hoop wood grain
arc 0.28,0.30 0.15 30 210 stroke #5c3a1e 0.5 width 1

# === Small stick for hoop (leaning inside) ===
rect 0.18,0.22 0.22,0.03 fill #5c3a1e 0.9
rect 0.18,0.22 0.22,0.03 stroke #2a1408

# === Wooden horse pull-toy (NE) ===
# Platform board with wheels
rect 0.58,0.20 0.30,0.12 texfill polyhaven/dark_wood 0.85
rect 0.58,0.20 0.30,0.12 stroke #2a1400
# Wheel circles
circle 0.62,0.32 0.035 fill #3a1f00 0.9
circle 0.62,0.32 0.035 stroke #1a0a04
circle 0.84,0.32 0.035 fill #3a1f00 0.9
circle 0.84,0.32 0.035 stroke #1a0a04
# Horse body (simple oval on platform)
ellipse 0.73,0.22 0.13,0.07 fill #c4a882 0.9
ellipse 0.73,0.22 0.13,0.07 stroke #5c3a1e
# Horse head (small bump)
poly 0.83,0.18 0.90,0.14 0.88,0.22 fill #c4a882 0.9
poly 0.83,0.18 0.90,0.14 0.88,0.22 stroke #5c3a1e
# Mane detail
line 0.82,0.14 0.86,0.12 stroke #5c3a1e width 2
line 0.80,0.16 0.84,0.14 stroke #5c3a1e width 2
# Pull string
bezier 0.60,0.24 0.48,0.38 0.38,0.48 0.26,0.52 stroke #8b7355 width 1

# === Spinning top (SW) ===
# Top body (triangular / conical from above = circle with tip dot)
