circle 0.28,0.68 0.09 stroke #5a1010
# Paint stripes (bands visible radiating)
arc 0.28,0.68 0.07 0 180 stroke #ffcc20 width 2
line 0.22,0.68 0.34,0.68 stroke #3080c0 width 2
# Tip point (small)
circle 0.28,0.68 0.018 fill #333333 0.95

# === Rag doll (SE) ===
# Head
