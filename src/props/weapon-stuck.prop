rect 0.47,0.42 0.06,0.10 stroke #333333 width 1
# Blood streak down the exposed blade
line 0.50,0.44 0.50,0.52 stroke #3a0000 0.75 width 1
# Grip wrap (leather-wrapped handle, above the crossguard)
rect 0.47,0.32 0.06,0.08 fill #2a1a10 0.95
