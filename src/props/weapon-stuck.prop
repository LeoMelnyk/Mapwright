circle 0.38,0.70 0.018 fill #4a0000 0.7
circle 0.60,0.42 0.016 fill #4a0000 0.7
# Impact slot — the blade's entry wound in the ground
rect 0.46,0.50 0.08,0.04 fill #0a0604 0.95
# Glimpse of blade tip above the impact (foreshortened)
rect 0.47,0.42 0.06,0.10 fill #888888 0.9
