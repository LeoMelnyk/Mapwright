line 0.47,0.34 0.53,0.36 stroke #1a1008 0.7 width 1
line 0.47,0.37 0.53,0.39 stroke #1a1008 0.7 width 1
# Crossguard — horizontal brass bar (widest element seen from above)
rect 0.28,0.38 0.44,0.06 fill #daa520 0.95
rect 0.28,0.38 0.44,0.06 texfill polyhaven/metal_plate 0.3
rect 0.28,0.38 0.44,0.06 stroke #5a3a00 width 1
# Crossguard end caps (flared quillons)
circle 0.28,0.41 0.05 fill #daa520 0.9
circle 0.28,0.41 0.05 stroke #5a3a00
circle 0.72,0.41 0.05 fill #daa520 0.9
circle 0.72,0.41 0.05 stroke #5a3a00
