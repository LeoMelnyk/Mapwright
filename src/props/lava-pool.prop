name: Lava Pool
category: Terrain
footprint: 2x2
facing: no
shadow: no
blocks_light: no
---
# Lava pool
ellipse 1.0,1.0 0.88,0.82 texfill polyhaven/volcanic_rock_tiles 0.8
ellipse 1.0,1.0 0.88,0.82 stroke #8b0000
# Hot center
ellipse 1.0,1.05 0.55,0.45 fill #ff4400 0.3
# Bright spots
circle 0.55,0.65 0.1 fill #ffaa00 0.5
circle 1.3,0.75 0.08 fill #ffaa00 0.4
circle 0.8,1.35 0.09 fill #ffaa00 0.45
# Crust edges
arc 0.4,0.5 0.2 180 280 stroke #4a0000
arc 1.6,1.4 0.2 0 100 stroke #4a0000
