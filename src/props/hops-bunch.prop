# footprint 1x1: x range 0-1, y range 0-1
# Top-down: cluster of green hop cones tied in a bundle with twine

# Twine binding (wraps around the middle of the bunch)
line 0.32,0.42 0.68,0.42 stroke #c8b898 width 2
line 0.32,0.58 0.68,0.58 stroke #c8b898 width 2
# Twine knot
circle 0.50,0.42 0.025 fill #c8b898 0.8
circle 0.50,0.42 0.025 stroke #8b7355

# Hop cones — green tear-shaped clusters radiating from center
# Top group
