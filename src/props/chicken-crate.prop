rect 0.08,0.62 0.84,0.10 stroke #3a1f00
rect 0.08,0.80 0.84,0.10 texfill polyhaven/weathered_planks 0.85
rect 0.08,0.80 0.84,0.10 stroke #3a1f00

# Frame border (thicker edge pieces)
rect 0.06,0.06 0.88,0.04 fill #4a2800 0.7
rect 0.06,0.06 0.88,0.04 stroke #2a1400
rect 0.06,0.90 0.88,0.04 fill #4a2800 0.7
rect 0.06,0.90 0.88,0.04 stroke #2a1400
