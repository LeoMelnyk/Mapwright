name: Chicken Crate
category: Containers
footprint: 1x1
facing: no
shadow: yes
blocks_light: no
placement: floor
room_types: market-square, farm, kitchen, village-green
typical_count: few
clusters_with: crate, produce-pile, sack, market-stall
notes: Slatted wooden crate holding live chickens. Top-down shows slat pattern with chicken heads peering through gaps.
---
# footprint 1x1: x range 0-1, y range 0-1
# Top-down: wooden slats across top, chicken heads visible between gaps

# Dark interior visible through slats
rect 0.10,0.10 0.80,0.80 fill #1a1208 0.7

# Wooden slats running east-west across the top
rect 0.08,0.08 0.84,0.10 texfill polyhaven/weathered_planks 0.85
rect 0.08,0.08 0.84,0.10 stroke #3a1f00
