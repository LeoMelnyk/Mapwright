# Border frame
rect 0.4,1.0 1.0,0.06 texfill polyhaven/dark_wood 0.85
rect 0.4,1.0 1.0,0.06 stroke #2a1400
rect 0.4,1.84 1.0,0.06 texfill polyhaven/dark_wood 0.85
rect 0.4,1.84 1.0,0.06 stroke #2a1400
rect 0.4,1.0 0.06,0.9 texfill polyhaven/dark_wood 0.85
rect 0.4,1.0 0.06,0.9 stroke #2a1400
rect 1.34,1.0 0.06,0.9 texfill polyhaven/dark_wood 0.85
rect 1.34,1.0 0.06,0.9 stroke #2a1400
