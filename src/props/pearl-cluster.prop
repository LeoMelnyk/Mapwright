name: Pearl Cluster
category: Decorative
footprint: 1x1
facing: no
shadow: yes
blocks_light: no
placement: floor
room_types: elemental-water-node, aquatic-shrine, sunken-temple, merfolk-grotto, coral-reef
typical_count: few
clusters_with: shell-scatter, shell-giant, anemone-small, sea-glass-shard
notes: Mother-of-pearl shell with pearls inside; soft glow makes it a subtle light source
lights: [{"preset":"silvery","x":0.5,"y":0.5,"radius":6,"intensity":0.5,"color":"#e0f0ff"}]
---
# Outer soft halo
circle 0.5,0.5 0.44 fill #e0f0ff 0.15
circle 0.5,0.5 0.34 fill #f0f8ff 0.20
# Clam shell base — fan shape (opened)
poly 0.15,0.70 0.25,0.35 0.50,0.22 0.75,0.35 0.85,0.70 0.75,0.78 0.50,0.82 0.25,0.78 fill #d0c0b0 0.9
