name: Quill
category: Library & Study
footprint: 1x1
facing: no
shadow: no
blocks_light: no
height: 0.2
placement: floor
room_types: bardic-hall, counting-house, courthouse-chamber, library, study, mansion-study, guildhall, scriptorium-mundane, scriptorium-dark, mansion-library
