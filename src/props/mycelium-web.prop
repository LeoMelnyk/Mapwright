name: Mycelium Web
category: Terrain
footprint: 2x2
facing: no
shadow: no
blocks_light: no
placement: floor
room_types: mushroom-grove, mushroom-cavern, cave-living, underdark-outpost, crypt
typical_count: few
clusters_with: mushroom, mushroom-cluster, glowcap-cluster, spore-pool, decaying-log
notes: Spreading web of white fungal mycelium strands across the floor — decorative floor decal beneath mushroom growth
---
# Very soft ground tint (almost invisible white wash)
ellipse 1.0,1.0 0.90,0.80 fill #f0e8d8 0.06

# Central mycelium node (where strands converge)
circle 1.0,1.0 0.10 fill #e8e0c8 0.55
circle 1.0,1.0 0.10 stroke #c8c0a8 0.6 width 1
circle 1.0,1.0 0.06 fill #f0e8d0 0.75

# Secondary nodes scattered across web
circle 0.55,0.42 0.05 fill #e8e0c8 0.5
circle 1.48,0.55 0.055 fill #e8e0c8 0.5
circle 0.42,1.50 0.05 fill #e8e0c8 0.5
circle 1.55,1.48 0.06 fill #e8e0c8 0.5
circle 0.32,0.95 0.04 fill #e8e0c8 0.45
circle 1.65,1.05 0.04 fill #e8e0c8 0.45
circle 0.95,0.30 0.04 fill #e8e0c8 0.45
circle 1.05,1.68 0.04 fill #e8e0c8 0.45

# Radial mycelium strands from center — thin bezier curves
bezier 1.00,1.00 0.80,0.80 0.65,0.55 0.55,0.42 stroke #e8e0c8 0.7 width 1
