bezier 0.32,0.95 0.18,0.92 0.10,0.88 0.04,0.82 stroke #c8c0a8 0.35 width 1
bezier 1.65,1.05 1.80,1.08 1.88,1.12 1.96,1.18 stroke #c8c0a8 0.35 width 1
bezier 0.95,0.30 0.92,0.18 0.90,0.10 0.88,0.04 stroke #c8c0a8 0.35 width 1
bezier 1.05,1.68 1.08,1.80 1.10,1.88 1.12,1.96 stroke #c8c0a8 0.35 width 1

