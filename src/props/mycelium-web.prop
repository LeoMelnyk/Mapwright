bezier 1.00,1.00 1.20,1.20 1.40,1.35 1.55,1.48 stroke #e8e0c8 0.7 width 1
bezier 1.00,1.00 0.70,1.00 0.50,0.98 0.32,0.95 stroke #e8e0c8 0.65 width 1
bezier 1.00,1.00 1.30,1.02 1.48,1.04 1.65,1.05 stroke #e8e0c8 0.65 width 1
bezier 1.00,1.00 0.98,0.70 0.97,0.50 0.95,0.30 stroke #e8e0c8 0.65 width 1
bezier 1.00,1.00 1.02,1.30 1.04,1.50 1.05,1.68 stroke #e8e0c8 0.65 width 1

# Secondary branches between nodes (fine web structure)
bezier 0.55,0.42 0.70,0.38 0.82,0.32 0.95,0.30 stroke #d8d0b8 0.5 width 1
bezier 0.95,0.30 1.15,0.32 1.35,0.42 1.48,0.55 stroke #d8d0b8 0.5 width 1
bezier 1.48,0.55 1.58,0.75 1.62,0.92 1.65,1.05 stroke #d8d0b8 0.5 width 1
bezier 1.65,1.05 1.62,1.25 1.60,1.38 1.55,1.48 stroke #d8d0b8 0.5 width 1
bezier 1.55,1.48 1.30,1.58 1.18,1.64 1.05,1.68 stroke #d8d0b8 0.5 width 1
bezier 1.05,1.68 0.82,1.64 0.55,1.60 0.42,1.50 stroke #d8d0b8 0.5 width 1
bezier 0.42,1.50 0.36,1.28 0.33,1.12 0.32,0.95 stroke #d8d0b8 0.5 width 1
bezier 0.32,0.95 0.36,0.78 0.44,0.58 0.55,0.42 stroke #d8d0b8 0.5 width 1

# Fine hyphae tendrils reaching out to edges
bezier 0.55,0.42 0.40,0.28 0.28,0.18 0.14,0.08 stroke #c8c0a8 0.4 width 1
