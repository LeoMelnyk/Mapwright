name: Cauldron (Fire)
category: Combat
footprint: 2x2
facing: yes
shadow: no
blocks_light: no
lights: [{"preset":"brazier","x":1.0,"y":1.0}]
placement: wall
room_types: fortification, battlements, gatehouse
