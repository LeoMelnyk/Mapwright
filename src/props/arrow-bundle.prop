name: Arrow Bundle
category: Combat
footprint: 1x1
facing: no
shadow: yes
blocks_light: no
height: 0.5
placement: floor
room_types: armory, gatehouse-inner, shop-weaponsmith, ranger-camp, hunting-lodge-large, guard-post
typical_count: few
clusters_with: weapon-rack, arrow-fletching, shield-rack, quiver, bow
notes: Bound sheaf of arrows standing upright or lying on ground
---
# === HITBOX ===
selection rect 0.30,0.14 0.40,0.72

# Ground shadow
ellipse 0.5,0.80 0.22,0.04 fill #1a1008 0.4
# Bundle binding cord (middle wrap)
rect 0.32,0.46 0.36,0.06 fill #3a2010 0.95
rect 0.32,0.46 0.36,0.06 stroke #1a0808
line 0.32,0.48 0.68,0.48 stroke #5c3a1e 0.7
# Second binding near top
rect 0.32,0.22 0.36,0.04 fill #3a2010 0.9
# === Arrows (bundle of ~7) ===
# Shafts (light wood, parallel)
line 0.34,0.20 0.34,0.78 stroke #8a6a30 width 1
line 0.38,0.20 0.38,0.78 stroke #8a6a30 width 1
line 0.42,0.20 0.42,0.78 stroke #a07840 width 1
line 0.46,0.20 0.46,0.78 stroke #8a6a30 width 1
