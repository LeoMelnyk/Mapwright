line 0.62,0.20 0.62,0.78 stroke #8a6a30 width 1
line 0.66,0.20 0.66,0.78 stroke #a07840 width 1
# Arrowheads (north tips, small triangles — iron)
poly 0.33,0.20 0.35,0.16 0.37,0.20 fill #555555 0.95
poly 0.37,0.20 0.39,0.16 0.41,0.20 fill #666666 0.95
