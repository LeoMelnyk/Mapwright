poly 0.61,0.20 0.63,0.16 0.65,0.20 fill #666666 0.95
poly 0.65,0.20 0.67,0.16 0.69,0.20 fill #555555 0.95
# Arrowhead outlines
poly 0.33,0.20 0.35,0.16 0.37,0.20 stroke #222222
poly 0.49,0.20 0.51,0.16 0.53,0.20 stroke #222222
poly 0.65,0.20 0.67,0.16 0.69,0.20 stroke #222222
