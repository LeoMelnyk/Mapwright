# Foot claws (3 splayed toes)
line 0.44,0.92 0.40,0.96 stroke #8a5010 width 1
line 0.44,0.92 0.44,0.98 stroke #8a5010 width 1
line 0.44,0.92 0.48,0.96 stroke #8a5010 width 1

# === Small feather fluff detail on tail ===
circle 0.46,0.32 0.012 fill #d8a878 0.7
circle 0.54,0.32 0.012 fill #d8a878 0.65
