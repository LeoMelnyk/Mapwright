name: Blood Smear
category: Effects
footprint: 1x1
facing: no
shadow: no
blocks_light: no
height: 0.01
placement: floor
room_types: butcher-shop, monster-lair-small, thieves-guild-hideout, corpse-scene, torture-chamber, interrogation-room
typical_count: few
