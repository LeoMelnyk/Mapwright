name: Straw Wisps
category: Scatter
footprint: 1x1
facing: no
shadow: no
blocks_light: no
height: 0.03
placement: floor
room_types: peasant-hovel, barn, stable, shepherds-shelter, croft, peasant-hut
typical_count: many
clusters_with: straw-pile, sheep-dung, bedroll, broom
notes: Loose straw scattered on the floor. Ground decal only.
---
# Ground scatter — no shadow, no light-block

# === Faint straw dust patch ===
ellipse 0.50,0.50 0.42,0.38 fill #8a7040 0.12

# === Loose straw pieces (lines in varied directions) ===
