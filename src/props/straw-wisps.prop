line 0.16,0.68 0.30,0.66 stroke #c8a860 0.8 width 1
line 0.22,0.76 0.38,0.74 stroke #d4b890 0.85 width 1
line 0.38,0.82 0.52,0.78 stroke #c8a860 0.8 width 1

# Middle area
line 0.42,0.24 0.58,0.30 stroke #c8a860 0.85 width 1
line 0.46,0.40 0.62,0.38 stroke #d4b890 0.85 width 1
line 0.40,0.50 0.56,0.52 stroke #c8a860 0.8 width 1
line 0.44,0.62 0.60,0.60 stroke #b89850 0.75 width 1
line 0.48,0.72 0.64,0.70 stroke #c8a860 0.8 width 1
line 0.52,0.82 0.68,0.84 stroke #d4b890 0.8 width 1

# East area
