line 0.66,0.40 0.82,0.36 stroke #b89850 0.8 width 1
line 0.60,0.50 0.76,0.50 stroke #d4b890 0.85 width 1
line 0.64,0.60 0.80,0.58 stroke #c8a860 0.8 width 1
line 0.70,0.70 0.84,0.72 stroke #b89850 0.8 width 1
line 0.66,0.78 0.82,0.80 stroke #c8a860 0.85 width 1

# Cross-angled pieces (for natural scatter feel)
line 0.30,0.22 0.26,0.38 stroke #b89850 0.7 width 1
line 0.52,0.20 0.48,0.34 stroke #c8a860 0.75 width 1
line 0.74,0.22 0.78,0.38 stroke #b89850 0.7 width 1
line 0.34,0.68 0.30,0.82 stroke #c8a860 0.75 width 1
line 0.56,0.68 0.52,0.82 stroke #b89850 0.7 width 1
