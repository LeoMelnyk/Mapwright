ellipse 0.52,0.66 0.14,0.08 stroke #806030
ellipse 0.48,0.64 0.09,0.05 fill #f8e0b8 0.85
ellipse 0.46,0.62 0.05,0.03 fill #ffe8c8 0.9
# Small spiral (lower left)
circle 0.22,0.72 0.07 fill #e8c080 0.88
circle 0.22,0.72 0.07 stroke #705020
circle 0.22,0.72 0.045 fill #f0d090 0.85
circle 0.23,0.71 0.02 fill #f8d8a0 0.9
# Small fan (lower right)
poly 0.78,0.66 0.86,0.70 0.86,0.80 0.76,0.82 0.72,0.74 fill #f0d0b0 0.85
poly 0.78,0.66 0.86,0.70 0.86,0.80 0.76,0.82 0.72,0.74 stroke #806040
line 0.78,0.66 0.78,0.82 stroke #806040 width 1
