name: Shell Scatter
category: Decorative
footprint: 1x1
facing: no
shadow: no
blocks_light: no
placement: floor
room_types: elemental-water-node, aquatic-shrine, sunken-temple, merfolk-grotto, coral-reef
typical_count: many
clusters_with: sea-glass-shard, pearl-cluster, anemone-small, fish-skeleton
notes: Assortment of small seashells; scatter densely to suggest tide-line debris
---
# Faint sand wash under scatter
ellipse 0.5,0.5 0.40,0.35 fill #c0b090 0.12
# Spiral shell (upper left) — conch-like spiral
circle 0.28,0.30 0.10 fill #e8c890 0.9
circle 0.28,0.30 0.10 stroke #806030
circle 0.28,0.30 0.07 fill #f0d8a0 0.85
