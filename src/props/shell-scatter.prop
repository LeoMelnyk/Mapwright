circle 0.30,0.28 0.02 fill #ffe8c0 0.9
line 0.18,0.30 0.38,0.30 stroke #806030 width 1
line 0.28,0.20 0.28,0.40 stroke #806030 width 1
# Fan shell (upper right) — ridged fan
poly 0.68,0.18 0.82,0.22 0.86,0.34 0.72,0.38 0.62,0.30 fill #f0d8c0 0.9
poly 0.68,0.18 0.82,0.22 0.86,0.34 0.72,0.38 0.62,0.30 stroke #8a6040
line 0.68,0.18 0.72,0.38 stroke #8a6040 width 1
line 0.74,0.20 0.76,0.38 stroke #8a6040 width 1
line 0.80,0.22 0.80,0.36 stroke #8a6040 width 1
# Conch shell (center lower) — elongated spiral
