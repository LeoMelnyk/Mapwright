name: Curtain Screen
category: Decorative
footprint: 1x2
facing: yes
shadow: no
blocks_light: no
height: 3
placement: wall
room_types: confessional, brothel-parlor, bath-house, dressing-room, temple, shrine
typical_count: few
clusters_with: curtain, curtain-divider, confessional-booth
notes: Wall-mounted hanging curtain divider — rod running east-west along the wall, gathered dark fabric top edge visible from above.
---
# === HITBOX ===
selection rect 0.06,0.04 1.88,0.22

# footprint 1x2: x 0-2, y 0-1. Wall attachment at north (low Y).
# Top-down: horizontal rod + narrow strip of gathered fabric top-edge.

# === Curtain rod (brass pole running east-west) ===
rect 0.06,0.04 1.88,0.06 fill #daa520 0.9
rect 0.06,0.04 1.88,0.06 stroke #5a3a00

# Rod highlight (catches light)
line 0.06,0.05 1.94,0.05 stroke #ffd860 0.6 width 1

# === Rod finials (decorative end caps) ===
circle 0.06,0.07 0.05 fill #daa520 0.95
circle 0.06,0.07 0.05 stroke #5a3a00
circle 0.06,0.07 0.02 fill #8b6914 0.8
circle 1.94,0.07 0.05 fill #daa520 0.95
circle 1.94,0.07 0.05 stroke #5a3a00
circle 1.94,0.07 0.02 fill #8b6914 0.8

# === Curtain rings spaced along rod ===
circle 0.20,0.10 0.022 fill #5a3a00 0.85
circle 0.20,0.10 0.022 stroke #3a2000 width 1
circle 0.40,0.10 0.022 fill #5a3a00 0.85
circle 0.40,0.10 0.022 stroke #3a2000 width 1
