poly 0.12,0.14 0.24,0.12 0.36,0.14 0.48,0.12 0.60,0.14 0.72,0.12 0.84,0.14 0.96,0.12 1.08,0.14 1.20,0.12 1.32,0.14 1.44,0.12 1.56,0.14 1.68,0.12 1.80,0.14 1.88,0.22 0.12,0.22 stroke #1a0008

