circle 1.40,0.10 0.022 stroke #3a2000 width 1
circle 1.60,0.10 0.022 fill #5a3a00 0.85
circle 1.60,0.10 0.022 stroke #3a2000 width 1
circle 1.80,0.10 0.022 fill #5a3a00 0.85
circle 1.80,0.10 0.022 stroke #3a2000 width 1

# === Curtain fabric top edge (pleated, dark velvet) ===
poly 0.12,0.14 0.24,0.12 0.36,0.14 0.48,0.12 0.60,0.14 0.72,0.12 0.84,0.14 0.96,0.12 1.08,0.14 1.20,0.12 1.32,0.14 1.44,0.12 1.56,0.14 1.68,0.12 1.80,0.14 1.88,0.22 0.12,0.22 fill #3a0a18 0.92
