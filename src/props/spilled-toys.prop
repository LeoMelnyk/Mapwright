circle 0.36,0.22 0.04 stroke #1a0a00
circle 0.36,0.22 0.015 fill #8b6914 0.8
# Pull string trailing south
bezier 0.16,0.34 0.12,0.46 0.18,0.56 0.22,0.62 stroke #8b7355 width 1

# === Stuffed rabbit (NE-center) ===
