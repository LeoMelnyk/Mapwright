# === Tipped toy cart (NW) ===
# Cart body — pale wood plank, tilted
rect 0.10,0.22 0.26,0.14 fill #d4a874 0.9 rotate -25
rect 0.10,0.22 0.26,0.14 stroke #8b5c28 rotate -25
