poly 1.54,0.84 1.60,0.76 1.66,0.84 1.64,0.92 1.60,0.96 1.56,0.92 stroke #daa520 width 1
# Tassel at base
ellipse 1.60,0.38 0.05,0.03 fill #8b1a1a 0.85
# Pommel
circle 1.60,0.22 0.05 fill #daa520 0.95
circle 1.60,0.22 0.05 stroke #5a3a00
