line 1.6,0.4 1.5,0.5 stroke #5a3a00 width 2
line 0.4,1.6 0.5,1.5 stroke #5a3a00 width 2
line 1.6,1.6 1.5,1.5 stroke #5a3a00 width 2

# Efreeti silhouette medallions on the brass rim (N/S/E/W)
circle 1.0,0.22 0.09 fill #8b6914 0.85
circle 1.0,0.22 0.09 stroke #5a3a00 width 1
poly 0.96,0.18 1.04,0.18 1.02,0.26 0.98,0.26 fill #1a0800 0.9
circle 1.0,1.78 0.09 fill #8b6914 0.85
circle 1.0,1.78 0.09 stroke #5a3a00 width 1
poly 0.96,1.74 1.04,1.74 1.02,1.82 0.98,1.82 fill #1a0800 0.9
circle 0.22,1.0 0.09 fill #8b6914 0.85
circle 0.22,1.0 0.09 stroke #5a3a00 width 1
circle 1.78,1.0 0.09 fill #8b6914 0.85
circle 1.78,1.0 0.09 stroke #5a3a00 width 1

# Inner metal bowl rim
circle 1.0,1.0 0.65 texfill polyhaven/metal_plate 0.85
circle 1.0,1.0 0.65 stroke #2a1500 width 2

# Charred bowl interior
circle 1.0,1.0 0.55 fill #1a0800 0.9

# Fire glow layers
circle 1.0,1.0 0.5 fill #e85500 0.5
circle 1.0,1.0 0.4 fill #ff6030 0.65
circle 1.0,1.0 0.3 fill #ff8030 0.75
