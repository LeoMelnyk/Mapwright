poly 0.35,0.62 0.65,0.62 0.50,0.88 fill #222222 0.5
poly 0.35,0.62 0.65,0.62 0.50,0.88 stroke #0a0a0a
# Glowing crack down the horn
line 0.50,0.64 0.50,0.84 stroke #cc2200 0.85 width 2

# Heel (flat back end - north side)
rect 0.22,0.22 0.56,0.12 texfill polyhaven/metal_plate 0.75
rect 0.22,0.22 0.56,0.12 fill #222222 0.5
rect 0.22,0.22 0.56,0.12 stroke #0a0a0a

# Horn spikes running along the top edge (small demonic barbs)
poly 0.26,0.22 0.30,0.14 0.34,0.22 fill #1a1a1a 0.95
poly 0.26,0.22 0.30,0.14 0.34,0.22 stroke #0a0a0a
poly 0.40,0.22 0.44,0.12 0.48,0.22 fill #1a1a1a 0.95
poly 0.40,0.22 0.44,0.12 0.48,0.22 stroke #0a0a0a
poly 0.54,0.22 0.58,0.12 0.62,0.22 fill #1a1a1a 0.95
poly 0.54,0.22 0.58,0.12 0.62,0.22 stroke #0a0a0a
poly 0.68,0.22 0.72,0.14 0.76,0.22 fill #1a1a1a 0.95
poly 0.68,0.22 0.72,0.14 0.76,0.22 stroke #0a0a0a

# Skull relief embossed on the side (bronze)
ellipse 0.50,0.54 0.06,0.05 fill #8a4018 0.9
ellipse 0.50,0.54 0.06,0.05 stroke #3a1800
# Skull eye sockets
circle 0.48,0.54 0.012 fill #0a0a0a 0.95
circle 0.52,0.54 0.012 fill #0a0a0a 0.95
# Skull jaw line
