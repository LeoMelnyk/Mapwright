---
# === HITBOX ===
hitbox rect 0.32,0.30 0.36,0.40 z 0-1.5
hitbox rect 0.15,0.22 0.70,0.46 z 1.5-2.5

# Base/waist (narrow column from above)
rect 0.32,0.30 0.36,0.40 texfill polyhaven/metal_plate 0.7
rect 0.32,0.30 0.36,0.40 fill #222222 0.55
rect 0.32,0.30 0.36,0.40 stroke #0a0a0a

# Main anvil face (dark iron)
rect 0.15,0.32 0.70,0.30 texfill polyhaven/metal_plate 0.75
rect 0.15,0.32 0.70,0.30 fill #222222 0.5
rect 0.15,0.32 0.70,0.30 stroke #0a0a0a

# Glowing red cracks across the face (hairline fractures leaking hellfire)
bezier 0.18,0.38 0.30,0.42 0.45,0.40 0.60,0.44 stroke #cc2200 0.9 width 2
bezier 0.60,0.44 0.70,0.46 0.78,0.48 0.82,0.50 stroke #ff4400 0.85 width 1
line 0.30,0.42 0.34,0.52 stroke #cc2200 0.85 width 2
line 0.50,0.40 0.54,0.50 stroke #ff4400 0.8 width 1

# Horn (pointed end facing south)
