name: Shrieker
category: Terrain
footprint: 1x1
facing: no
shadow: yes
blocks_light: yes
height: 1.5
placement: floor
room_types: mushroom-cavern, mushroom-grove, underdark-outpost, cave-living, dungeon-deep
