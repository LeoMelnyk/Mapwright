# Main cap surface (deep magenta-red)
poly 0.22,0.50 0.28,0.32 0.40,0.22 0.52,0.20 0.64,0.24 0.74,0.34 0.78,0.50 0.72,0.66 0.58,0.76 0.50,0.78 0.38,0.74 0.28,0.64 fill #8a1a48 0.90
