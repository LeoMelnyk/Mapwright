notes: Large screaming fungal creature — magenta cap with dark mouth gap that wails when disturbed. Alarm fungus.
---
# === HITBOX ===
hitbox circle 0.5,0.50 0.36 z 0-1.5

# Ground shadow
circle 0.52,0.54 0.40 fill #2a0a10 0.35
circle 0.52,0.54 0.32 fill #1a0408 0.28

# Outer cap rim (dark magenta edge, irregular organic shape)
poly 0.14,0.50 0.20,0.28 0.36,0.16 0.50,0.12 0.66,0.16 0.80,0.28 0.86,0.50 0.80,0.70 0.64,0.82 0.50,0.86 0.34,0.82 0.20,0.70 fill #4a0a28 0.92
