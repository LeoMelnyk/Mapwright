# Brighter pink-magenta zones (engorged flesh)
ellipse 0.38,0.38 0.10,0.08 fill #b83068 0.70
ellipse 0.62,0.40 0.09,0.07 fill #b83068 0.65
ellipse 0.44,0.60 0.11,0.09 fill #b83068 0.60

# Pale blotches (sickly patches)
circle 0.34,0.52 0.045 fill #c88898 0.55
circle 0.64,0.56 0.040 fill #c88898 0.50
circle 0.50,0.32 0.035 fill #c88898 0.55

# Central mouth gap (the screaming maw — dark jagged hole)
poly 0.38,0.46 0.44,0.44 0.48,0.48 0.52,0.42 0.58,0.46 0.62,0.50 0.58,0.56 0.54,0.60 0.48,0.62 0.42,0.58 0.38,0.54 fill #0a0204 1.0
