# Inner mouth darkness (pitch black gullet)
poly 0.42,0.50 0.48,0.48 0.54,0.52 0.52,0.58 0.46,0.58 fill #000000 1.0

# Ragged "teeth" / cap gill edges lining the maw
line 0.40,0.46 0.42,0.50 stroke #4a0818 width 1
line 0.46,0.44 0.47,0.48 stroke #4a0818 width 1
line 0.54,0.44 0.53,0.48 stroke #4a0818 width 1
line 0.60,0.48 0.58,0.52 stroke #4a0818 width 1
line 0.58,0.58 0.56,0.60 stroke #4a0818 width 1
line 0.44,0.60 0.45,0.56 stroke #4a0818 width 1

# Surface warts / pustules
circle 0.30,0.30 0.020 fill #3a0818 0.9
circle 0.68,0.32 0.018 fill #3a0818 0.85
circle 0.72,0.56 0.022 fill #3a0818 0.9
circle 0.28,0.62 0.019 fill #3a0818 0.85
circle 0.54,0.70 0.016 fill #3a0818 0.8

# Small bright highlight (catches light — wet, fleshy)
arc 0.50,0.50 0.30 220 250 stroke #d89080 0.5 width 2

# Vein-like dark lines radiating from the maw
bezier 0.44,0.58 0.38,0.68 0.32,0.76 0.28,0.82 stroke #2a0408 0.6 width 1
bezier 0.56,0.56 0.64,0.66 0.70,0.74 0.76,0.80 stroke #2a0408 0.6 width 1
bezier 0.42,0.46 0.34,0.36 0.28,0.26 0.24,0.18 stroke #2a0408 0.5 width 1
