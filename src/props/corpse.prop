poly 0.7,0.9 0.75,0.85 0.9,1.15 0.88,1.25 0.72,1.0 stroke #2a2018
# Right hand
circle 0.89,1.2 0.05 fill #c4a882 0.45

# === Head (north end, face down) ===
ellipse 0.48,0.5 0.18,0.22 fill #c4a882 0.55
ellipse 0.48,0.5 0.18,0.22 stroke #8b7d6b
# Hair
ellipse 0.48,0.42 0.16,0.15 fill #3a2a1a 0.5
