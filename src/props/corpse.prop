poly 0.25,0.7 0.7,0.7 0.72,1.7 0.65,1.75 0.3,1.75 0.22,1.7 stroke #2a2018
# Belt
rect 0.25,1.55 0.45,0.08 fill #2a1a10 0.6
rect 0.25,1.55 0.45,0.08 stroke #1a1008
# Belt buckle
rect 0.44,1.55 0.08,0.08 fill #8b6914 0.5

# === Arms ===
# Left arm (sprawled out west)
poly 0.25,0.85 0.22,0.9 0.05,1.3 0.0,1.25 0.12,0.85 fill #4a3a28 0.6
poly 0.25,0.85 0.22,0.9 0.05,1.3 0.0,1.25 0.12,0.85 stroke #2a2018
# Left hand
circle 0.02,1.28 0.05 fill #c4a882 0.45
# Right arm (bent, closer to body)
