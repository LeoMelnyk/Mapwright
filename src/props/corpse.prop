name: Corpse
category: Misc
footprint: 3x1
padding: 0.1
facing: yes
shadow: no
blocks_light: no
placement: floor
room_types: dungeon, crypt, battlefield, cave
typical_count: few
clusters_with: bone-pile, skeleton
notes: Scatter on floor for grim atmosphere; vary rotation for natural look
---
# footprint 3x1: x range 0-1, y range 0-3
# Top-down: body lying face down, head north, feet south

# Blood pool (underneath everything)
ellipse 0.55,1.2 0.3,0.35 fill #4a0000 0.25
ellipse 0.45,1.4 0.2,0.2 fill #4a0000 0.15

# === Legs (south end) ===
# Left leg
poly 0.3,1.7 0.35,1.7 0.38,2.6 0.28,2.6 fill #3a3020 0.6
poly 0.3,1.7 0.35,1.7 0.38,2.6 0.28,2.6 stroke #2a2018
# Left boot
poly 0.26,2.55 0.4,2.55 0.4,2.7 0.26,2.72 fill #2a1a10 0.7
poly 0.26,2.55 0.4,2.55 0.4,2.7 0.26,2.72 stroke #1a1008
# Right leg (slightly splayed)
poly 0.6,1.7 0.65,1.7 0.72,2.55 0.62,2.55 fill #3a3020 0.6
poly 0.6,1.7 0.65,1.7 0.72,2.55 0.62,2.55 stroke #2a2018
# Right boot
