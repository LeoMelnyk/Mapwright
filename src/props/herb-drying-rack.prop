ellipse 0.54,0.36 0.09,0.14 fill #6a7a3a 0.9
ellipse 0.54,0.36 0.09,0.14 stroke #2a3810
line 0.50,0.46 0.48,0.56 stroke #3a5018 width 1
line 0.58,0.46 0.60,0.56 stroke #3a5018 width 1

