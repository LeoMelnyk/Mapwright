poly 0.50,0.26 0.62,0.50 0.50,0.58 0.38,0.50 stroke #3366aa
# Facet highlights
line 0.50,0.26 0.50,0.58 stroke #aaddff 0.6
line 0.38,0.50 0.62,0.50 stroke #aaddff 0.35

# Secondary crystal (right)
poly 0.68,0.46 0.78,0.62 0.70,0.68 0.58,0.58 fill #5a9adc 0.8
poly 0.68,0.46 0.78,0.62 0.70,0.68 0.58,0.58 stroke #2a5a9a
line 0.68,0.46 0.70,0.68 stroke #aaddff 0.5

# Secondary crystal (left)
