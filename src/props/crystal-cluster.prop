poly 0.30,0.50 0.40,0.62 0.32,0.70 0.22,0.58 stroke #2a5a9a
line 0.30,0.50 0.32,0.70 stroke #aaddff 0.5

# Bright tip highlights (catching light)
circle 0.50,0.26 0.03 fill #ffffff 0.8
circle 0.68,0.46 0.025 fill #ffffff 0.7
circle 0.30,0.50 0.025 fill #ffffff 0.7
