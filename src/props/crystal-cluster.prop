# === HITBOX ===
hitbox circle 0.5,0.5 0.26 z 0-2

# Faint halo glow
circle 0.50,0.50 0.40 fill #4488cc 0.12
circle 0.50,0.50 0.30 fill #66aaee 0.18

# Rock base (drawn first)
poly 0.25,0.70 0.38,0.60 0.55,0.58 0.72,0.64 0.78,0.74 0.68,0.82 0.42,0.84 0.28,0.80 fill #2a2838 0.85
