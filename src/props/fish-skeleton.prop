qbezier 0.98,0.52 1.02,0.34 1.08,0.22 stroke #d4c4a8 width 2
qbezier 1.14,0.52 1.18,0.36 1.24,0.26 stroke #d4c4a8 width 2
qbezier 1.30,0.52 1.32,0.38 1.36,0.30 stroke #d4c4a8 width 2
qbezier 1.44,0.52 1.46,0.42 1.48,0.36 stroke #c8b898 width 2
# Rib bones — lower (curving down from spine)
qbezier 0.40,0.52 0.42,0.66 0.46,0.74 stroke #d4c4a8 width 2
qbezier 0.52,0.52 0.55,0.68 0.60,0.78 stroke #d4c4a8 width 2
qbezier 0.66,0.52 0.70,0.70 0.76,0.82 stroke #d4c4a8 width 2
qbezier 0.82,0.52 0.86,0.70 0.92,0.82 stroke #d4c4a8 width 2
qbezier 0.98,0.52 1.02,0.70 1.08,0.82 stroke #d4c4a8 width 2
qbezier 1.14,0.52 1.18,0.68 1.24,0.78 stroke #d4c4a8 width 2
qbezier 1.30,0.52 1.32,0.66 1.36,0.74 stroke #d4c4a8 width 2
qbezier 1.44,0.52 1.46,0.62 1.48,0.68 stroke #c8b898 width 2
# Tail fan (east end)
poly 1.70,0.52 1.92,0.30 1.85,0.50 1.92,0.74 fill #e8dcc8 0.85
poly 1.70,0.52 1.92,0.30 1.85,0.50 1.92,0.74 stroke #8a7a6a
line 1.70,0.52 1.90,0.34 stroke #b0a090 width 1
line 1.70,0.52 1.86,0.52 stroke #b0a090 width 1
