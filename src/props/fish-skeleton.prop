name: Fish Skeleton
category: Decorative
footprint: 1x2
facing: yes
shadow: no
blocks_light: no
placement: floor
room_types: elemental-water-node, sunken-temple, merfolk-grotto, coral-reef
typical_count: few
clusters_with: shell-scatter, sea-glass-shard, bone-pile, fish-skeleton
notes: Skeletal fish on the floor; place as atmospheric detail in aquatic rooms
---
# Footprint 1x2: x 0-2, y 0-1. Fish laid horizontally, head at west, tail at east.
# Subtle sand stain under skeleton
ellipse 1.0,0.55 0.90,0.22 fill #807060 0.15
# Spine — central horizontal bone
line 0.28,0.52 1.70,0.52 stroke #e8dcc8 width 3
line 0.28,0.52 1.70,0.52 stroke #b0a090 width 1
# Skull (west end)
poly 0.10,0.52 0.15,0.40 0.25,0.36 0.34,0.40 0.36,0.50 0.34,0.60 0.25,0.64 0.15,0.60 fill #e8dcc8 0.9
poly 0.10,0.52 0.15,0.40 0.25,0.36 0.34,0.40 0.36,0.50 0.34,0.60 0.25,0.64 0.15,0.60 stroke #8a7a6a
# Eye socket
circle 0.22,0.48 0.035 fill #1a1010 0.85
# Jaw line
line 0.12,0.54 0.34,0.54 stroke #8a7a6a width 1
# Rib bones — upper (curving up from spine)
qbezier 0.40,0.52 0.42,0.38 0.46,0.30 stroke #d4c4a8 width 2
qbezier 0.52,0.52 0.55,0.36 0.60,0.26 stroke #d4c4a8 width 2
