line 0.56,0.34 0.62,0.40 stroke #222222 width 1
line 0.52,0.36 0.58,0.42 stroke #222222 width 1

# === Gauntlet 3 (bottom, half-buried) ===
ellipse 0.56,0.72 0.11,0.07 texfill polyhaven/metal_plate 0.8
ellipse 0.56,0.72 0.11,0.07 stroke #333333 width 1
ellipse 0.56,0.72 0.06,0.04 fill #1a1a1a 0.9
# Finger plates (partial, peeking south)
