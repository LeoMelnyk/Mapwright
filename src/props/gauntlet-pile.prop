# footprint 1x1: x 0-1, y 0-1
# Top-down: jumbled pile of metal gauntlets. Cuff openings as dark ovals, overlapping finger plates fanning outward.

# Ground smudge
ellipse 0.5,0.5 0.40,0.34 fill #1a1208 0.25

# === Gauntlet 1 (bottom-left, cuff north-west) ===
# Wrist cuff
ellipse 0.28,0.36 0.12,0.08 texfill polyhaven/metal_plate 0.85
ellipse 0.28,0.36 0.12,0.08 stroke #333333 width 1
# Cuff opening (dark)
ellipse 0.28,0.36 0.07,0.045 fill #1a1a1a 0.9
# Finger plates fanning south-east
poly 0.32,0.42 0.50,0.48 0.56,0.60 0.38,0.58 0.30,0.50 texfill polyhaven/metal_plate 0.8
poly 0.32,0.42 0.50,0.48 0.56,0.60 0.38,0.58 0.30,0.50 stroke #333333
# Knuckle ridges
line 0.36,0.48 0.44,0.54 stroke #222222 width 1
line 0.40,0.44 0.48,0.52 stroke #222222 width 1
line 0.44,0.42 0.52,0.50 stroke #222222 width 1

# === Gauntlet 2 (top-right, cuff east) ===
ellipse 0.74,0.40 0.12,0.08 texfill polyhaven/metal_plate 0.85
