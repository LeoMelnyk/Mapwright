poly 0.86,0.52 0.92,0.58 0.88,0.64 0.80,0.60 stroke #2a5018 width 1
# SE
poly 0.72,0.74 0.80,0.74 0.78,0.82 0.68,0.80 fill #4a8030 0.88
poly 0.72,0.74 0.80,0.74 0.78,0.82 0.68,0.80 stroke #2a5018 width 1
# South
poly 0.48,0.86 0.54,0.82 0.58,0.90 0.52,0.94 fill #5a9038 0.9
poly 0.48,0.86 0.54,0.82 0.58,0.90 0.52,0.94 stroke #2a5018 width 1
poly 0.38,0.86 0.44,0.82 0.48,0.90 0.42,0.94 fill #4a8030 0.88
poly 0.38,0.86 0.44,0.82 0.48,0.90 0.42,0.94 stroke #2a5018 width 1
# SW
poly 0.20,0.72 0.28,0.72 0.30,0.80 0.22,0.82 fill #5a9038 0.88
poly 0.20,0.72 0.28,0.72 0.30,0.80 0.22,0.82 stroke #2a5018 width 1
# West
poly 0.08,0.42 0.16,0.46 0.18,0.54 0.10,0.56 fill #4a8030 0.9
poly 0.08,0.42 0.16,0.46 0.18,0.54 0.10,0.56 stroke #2a5018 width 1
poly 0.10,0.52 0.18,0.56 0.20,0.64 0.12,0.64 fill #5a9038 0.88
poly 0.10,0.52 0.18,0.56 0.20,0.64 0.12,0.64 stroke #2a5018 width 1
# NW
poly 0.20,0.20 0.28,0.18 0.30,0.26 0.22,0.28 fill #4a8030 0.88
poly 0.20,0.20 0.28,0.18 0.30,0.26 0.22,0.28 stroke #2a5018 width 1

# Gold ribbon tied at the south with trailing tails
rect 0.44,0.84 0.12,0.06 fill #daa520 0.95
rect 0.44,0.84 0.12,0.06 stroke #5a3a00 width 1
# Ribbon tails
bezier 0.46,0.90 0.42,0.94 0.40,0.96 0.38,0.96 stroke #daa520 width 3
