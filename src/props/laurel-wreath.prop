name: Laurel Wreath
category: Decorative
footprint: 1x1
facing: no
shadow: no
blocks_light: no
height: 0.05
placement: wall
room_types: bardic-hall, music-hall, theater, bards-college, temple-nave, memorial
typical_count: few
clusters_with: bouquet, flower-petals, stage-large, banner-religious
notes: Circular wreath of green laurel leaves bound with a gold ribbon — lies flat on the floor or hangs flat against the wall (top-down shows a ring of overlapping leaves)
---
# footprint 1x1 — flat ring, no shadow

# Faint background shadow ring (very subtle floor hint)
ring 0.5,0.5 0.40 0.30 fill #000000 0.08

# Inner laurel ring base (dark green)
ring 0.5,0.5 0.40 0.28 fill #3a6020 0.9
ring 0.5,0.5 0.40 0.28 stroke #1a3010 width 1

# Overlapping laurel leaves around the ring (pairs of small polygons)
# North
poly 0.42,0.10 0.48,0.06 0.52,0.14 0.46,0.18 fill #4a8030 0.9
poly 0.42,0.10 0.48,0.06 0.52,0.14 0.46,0.18 stroke #2a5018 width 1
poly 0.52,0.10 0.58,0.06 0.62,0.14 0.56,0.18 fill #5a9038 0.88
poly 0.52,0.10 0.58,0.06 0.62,0.14 0.56,0.18 stroke #2a5018 width 1
# NE
