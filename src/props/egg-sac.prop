# Main sac body (irregular blob — sickly yellow-grey membrane)
poly 0.24,0.44 0.30,0.28 0.44,0.20 0.58,0.22 0.72,0.32 0.78,0.48 0.76,0.64 0.66,0.76 0.50,0.80 0.34,0.76 0.24,0.64 0.20,0.54 fill #b8b088 0.92
