bezier 0.44,0.26 0.48,0.40 0.52,0.52 0.54,0.66 stroke #5a4020 0.5 width 1

# Dark egg shapes visible inside through translucent membrane
ellipse 0.40,0.40 0.07,0.06 fill #2a1a08 0.75
ellipse 0.58,0.46 0.07,0.06 fill #2a1a08 0.78
ellipse 0.46,0.58 0.07,0.06 fill #2a1a08 0.75
ellipse 0.62,0.62 0.05,0.05 fill #2a1a08 0.7

# Faint inner shadows on eggs (curled embryos)
