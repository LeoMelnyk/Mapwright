# footprint 1x2: x range 0-2, y range 0-1
# === HITBOX ===
hitbox ellipse 0.55,0.55 0.40,0.40 z 0-1.2
hitbox ellipse 1.45,0.55 0.40,0.40 z 0-1.2
hitbox ellipse 1.00,0.50 0.38,0.36 z 0-1.2

# === West sack (bottom of pile) ===
