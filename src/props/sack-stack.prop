ellipse 0.55,0.58 0.40,0.36 fill #9a8260 0.35
ellipse 0.55,0.58 0.40,0.36 stroke #3a2810
# Content bulges
ellipse 0.42,0.58 0.10,0.08 fill #b8a580 0.4
ellipse 0.68,0.62 0.10,0.08 fill #b8a580 0.4
# Drawstring gather
