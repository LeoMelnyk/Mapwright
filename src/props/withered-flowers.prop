name: Withered Flowers
category: Decorative
footprint: 1x1
facing: no
shadow: no
blocks_light: no
height: 0.3
placement: floor
room_types: graveyard-village, roadside-gallows, shadowfell-mausoleum, crypt, shrine-roadside, tomb
