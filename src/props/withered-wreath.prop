name: Withered Wreath
category: Decor
footprint: 1x1
facing: no
shadow: no
blocks_light: no
height: 0.1
placement: floor
room_types: crypt, shrine-roadside, graveyard-village, shadowfell-mausoleum
typical_count: single
clusters_with: withered-flowers, candle-guttered, fresh-dirt-mound, skull-small
notes: Dead circular wreath lying on a grave — brown twisted branches
---
# === HITBOX ===
hitbox circle 0.5,0.5 0.32 z 0-0.1

# Wreath base (braided brown branches — ring shape)
ring 0.5,0.5 0.34 0.20 fill #4a3020 0.92
ring 0.5,0.5 0.34 0.20 stroke #2a1408
# Twisted branch details (darker weave lines)
arc 0.5,0.5 0.30 0 60 stroke #2a1408 0.8 width 2
arc 0.5,0.5 0.30 60 120 stroke #1a0f00 0.8 width 2
arc 0.5,0.5 0.30 120 180 stroke #2a1408 0.8 width 2
arc 0.5,0.5 0.30 180 240 stroke #1a0f00 0.8 width 2
arc 0.5,0.5 0.30 240 300 stroke #2a1408 0.8 width 2
arc 0.5,0.5 0.30 300 360 stroke #1a0f00 0.8 width 2
# Braid crossover bumps
circle 0.72,0.30 0.02 fill #5c3a1e 0.85
circle 0.78,0.56 0.02 fill #5c3a1e 0.85
circle 0.56,0.76 0.02 fill #5c3a1e 0.85
circle 0.26,0.70 0.02 fill #5c3a1e 0.85
circle 0.22,0.42 0.02 fill #5c3a1e 0.85
circle 0.38,0.22 0.02 fill #5c3a1e 0.85
# Dead leaves attached (brown, curled)
poly 0.68,0.24 0.72,0.20 0.76,0.26 0.72,0.30 fill #5a3018 0.9
