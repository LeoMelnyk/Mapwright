poly 0.82,0.54 0.86,0.52 0.88,0.58 0.82,0.60 stroke #2a1408
poly 0.28,0.76 0.24,0.80 0.18,0.74 0.22,0.70 fill #5a3018 0.9
poly 0.28,0.76 0.24,0.80 0.18,0.74 0.22,0.70 stroke #2a1408
# Dead flowers (shriveled, dark red/brown)
circle 0.50,0.20 0.04 fill #4a1010 0.85
circle 0.50,0.20 0.04 stroke #2a0808
circle 0.80,0.70 0.035 fill #4a1010 0.85
circle 0.80,0.70 0.035 stroke #2a0808
circle 0.22,0.60 0.03 fill #4a2040 0.85
circle 0.22,0.60 0.03 stroke #2a1020
# Faded purple dried flower
circle 0.72,0.76 0.03 fill #3a1040 0.85
circle 0.72,0.76 0.03 stroke #2a0820
# Ribbon (faded black mourning tie)
poly 0.44,0.18 0.56,0.18 0.58,0.26 0.50,0.24 0.42,0.26 fill #1a1008 0.85
poly 0.44,0.18 0.56,0.18 0.58,0.26 0.50,0.24 0.42,0.26 stroke #0a0404
# Ribbon tails trailing
line 0.42,0.24 0.38,0.12 stroke #1a1008 width 2
line 0.58,0.24 0.62,0.12 stroke #1a1008 width 2
# Cobweb/decay threads
bezier 0.40,0.36 0.48,0.42 0.56,0.40 0.62,0.44 stroke #aaaaaa 0.4 width 1
bezier 0.36,0.60 0.46,0.58 0.54,0.62 0.64,0.58 stroke #aaaaaa 0.35 width 1
