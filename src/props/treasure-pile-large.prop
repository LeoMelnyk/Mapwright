circle 3.75,2.10 0.05 fill #daa520 0.55
circle 1.0,0.70 0.06 fill #ffd700 0.6
circle 3.0,2.55 0.06 fill #daa520 0.6
# === Chest 1 — large open chest (center-left) ===
# Chest body
rect 0.60,0.80 0.75,0.45 texfill polyhaven/dark_wood 0.85
rect 0.60,0.80 0.75,0.45 stroke #4a2800
# Open lid (hinged north, flipped open)
rect 0.60,0.55 0.75,0.25 texfill polyhaven/dark_wood 0.75
rect 0.60,0.55 0.75,0.25 stroke #4a2800
# Gold visible inside open chest
ellipse 0.97,1.0 0.28,0.12 fill #ffd700 0.6
# Iron bands
line 0.60,0.95 1.35,0.95 stroke #555555 width 2
line 0.60,1.18 1.35,1.18 stroke #555555 width 2
# Clasp (open)
rect 0.90,0.80 0.14,0.06 fill #daa520 0.7
# === Chest 2 — closed chest (right side) ===
rect 2.70,0.65 0.65,0.35 texfill polyhaven/dark_wood 0.85
rect 2.70,0.65 0.65,0.35 stroke #4a2800
# Clasp
rect 2.95,0.65 0.12,0.06 fill #daa520 0.8
rect 2.95,0.65 0.12,0.06 stroke #8b6914
# Iron bands
line 2.70,0.80 3.35,0.80 stroke #555555 width 2
line 2.70,0.93 3.35,0.93 stroke #555555 width 2
# === Chest 3 — small chest half-buried (far right) ===
rect 3.15,1.70 0.50,0.28 texfill polyhaven/dark_wood 0.8
rect 3.15,1.70 0.50,0.28 stroke #4a2800
rect 3.33,1.70 0.10,0.06 fill #daa520 0.75
line 3.15,1.82 3.65,1.82 stroke #555555 width 2
