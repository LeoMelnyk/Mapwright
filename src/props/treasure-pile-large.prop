name: Treasure Pile (Large)
category: Features
footprint: 3x4
facing: no
shadow: yes
blocks_light: no
placement: center
room_types: vault, dragon-lair, treasure-room
typical_count: single
clusters_with: chest, treasure-pile
notes: Major treasure hoard; place as room focal point
---
# footprint 3x4: x range 0-4, y range 0-3
# === Base layer — multiple overlapping gold mounds ===
# Large shadow base
ellipse 2.0,1.6 1.7,1.2 fill #8b6914 0.25
# Main mound (center)
ellipse 2.0,1.5 1.5,1.0 fill #c49520 0.45
# Secondary mound (left)
ellipse 1.1,1.7 0.8,0.6 fill #c49520 0.4
# Secondary mound (right)
ellipse 2.9,1.4 0.75,0.55 fill #c49520 0.4
# Bright center layer
ellipse 2.0,1.4 1.1,0.75 fill #daa520 0.5
# Left bright
ellipse 1.1,1.6 0.55,0.4 fill #daa520 0.45
# Right bright
ellipse 2.9,1.3 0.5,0.35 fill #daa520 0.45
# Highlight peaks
ellipse 2.0,1.3 0.6,0.4 fill #ffd700 0.4
ellipse 1.1,1.5 0.3,0.2 fill #ffd700 0.35
ellipse 2.9,1.2 0.28,0.2 fill #ffd700 0.35
