name: Bed
category: Furniture
footprint: 2x1
facing: yes
shadow: yes
blocks_light: no
---
# Wooden frame
rect 0.05,0.05 0.9,1.9 texfill polyhaven/dark_wood 0.8
rect 0.05,0.05 0.9,1.9 stroke #3a1f00
# Mattress / blanket
rect 0.12,0.12 0.76,1.76 texfill polyhaven/rough_linen 0.85
rect 0.12,0.12 0.76,1.76 stroke #8b7d6b
# Pillow
ellipse 0.5,0.28 0.25,0.1 fill #e8dcc8 0.9
ellipse 0.5,0.28 0.25,0.1 stroke #b0a090
# Blanket fold line
line 0.15,0.6 0.85,0.6
