name: Small Animal Skull (Tiny)
category: Decor
footprint: 1x1
facing: no
shadow: no
blocks_light: no
placement: floor
room_types: bog-witch-hut, cabin-witch, graveyard-village, druid-grove, hermit-cell, hunter-camp, beast-den
