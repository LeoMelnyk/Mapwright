circle 1.00,1.80 0.09 stroke #333333
circle 0.35,1.65 0.09 fill #777777 0.9
circle 0.35,1.65 0.09 stroke #333333

# === Ash / charred ground inside stones ===
circle 1.0,1.0 0.75 fill #1a0800 0.7

# === Log pyramid (stacked crossed logs visible as X-pattern) ===
# Bottom log NE-SW
rect 0.40,0.92 1.20,0.16 texfill polyhaven/dark_wood 0.9
rect 0.40,0.92 1.20,0.16 stroke #1a0800 width 2
# Bottom log NW-SE
rect 0.92,0.40 0.16,1.20 texfill polyhaven/dark_wood 0.9
rect 0.92,0.40 0.16,1.20 stroke #1a0800 width 2
# Log ends charred
circle 0.42,1.00 0.07 fill #1a0800 0.9
circle 1.58,1.00 0.07 fill #1a0800 0.9
circle 1.00,0.42 0.07 fill #1a0800 0.9
circle 1.00,1.58 0.07 fill #1a0800 0.9

# === Flames (top-down — concentric rings of fire climbing the log pyramid) ===
# Outer heat halo
circle 1.0,1.0 0.70 fill #e85500 0.30
# Outer flame ring (ragged edge)
poly 1.00,0.32 1.20,0.42 1.42,0.48 1.58,0.66 1.68,1.00 1.58,1.34 1.42,1.52 1.20,1.58 1.00,1.68 0.80,1.58 0.58,1.52 0.42,1.34 0.32,1.00 0.42,0.66 0.58,0.48 0.80,0.42 fill #ff6020 0.80
# Mid flame ring (bright orange)
circle 1.0,1.0 0.45 fill #ff8030 0.85
# Flame tongues radiating outward
poly 1.00,0.30 0.92,0.50 1.08,0.50 fill #ffaa30 0.85
poly 1.00,1.70 0.92,1.50 1.08,1.50 fill #ff8030 0.80
poly 0.30,1.00 0.50,0.92 0.50,1.08 fill #ffaa30 0.80
poly 1.70,1.00 1.50,0.92 1.50,1.08 fill #ff8030 0.80
poly 0.48,0.48 0.64,0.62 0.62,0.64 fill #ffaa30 0.75
poly 1.52,0.48 1.36,0.62 1.38,0.64 fill #ffaa30 0.75
poly 0.48,1.52 0.62,1.36 0.64,1.38 fill #ff8030 0.75
poly 1.52,1.52 1.36,1.36 1.38,1.38 fill #ff8030 0.75
# Inner yellow ring
circle 1.0,1.0 0.32 fill #ffcc60 0.88
# Hot white-yellow core
circle 1.0,1.0 0.20 fill #ffe890 0.92
# Hottest white center (looking down the flame's axis)
circle 1.0,1.0 0.10 fill #ffffff 0.95
