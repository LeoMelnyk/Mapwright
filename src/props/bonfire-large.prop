# footprint 2x2: x range 0-2, y range 0-2

# === HITBOX ===
selection circle 1.0,1.0 0.60

# === Stone ring at base ===
# Ring of stones around perimeter
circle 0.20,1.00 0.09 fill #666666 0.9
circle 0.20,1.00 0.09 stroke #333333
circle 0.35,0.45 0.09 fill #777777 0.9
circle 0.35,0.45 0.09 stroke #333333
circle 1.00,0.20 0.09 fill #666666 0.9
circle 1.00,0.20 0.09 stroke #333333
