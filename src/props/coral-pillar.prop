poly 0.90,1.10 1.10,1.10 1.06,1.65 1.00,1.90 0.94,1.65 stroke #802010
# SW branch
poly 0.92,1.12 0.82,1.18 0.38,1.72 0.28,1.82 0.42,1.58 fill #e05030 0.80
poly 0.92,1.12 0.82,1.18 0.38,1.72 0.28,1.82 0.42,1.58 stroke #802010
# West branch
poly 0.90,1.08 0.90,0.92 0.28,0.98 0.10,1.00 0.28,1.05 fill #ff6040 0.82
poly 0.90,1.08 0.90,0.92 0.28,0.98 0.10,1.00 0.28,1.05 stroke #802010
# NW branch
