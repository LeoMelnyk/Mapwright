name: Coral Pillar
category: Nature
footprint: 2x2
facing: no
shadow: yes
blocks_light: yes
height: 1.8
placement: corner
room_types: elemental-water-node, coral-reef, aquatic-shrine, merfolk-grotto
typical_count: few
clusters_with: anemone-glow, anemone-small, shell-scatter, kelp-strand
notes: Branching coral seen from above — a rosette of fingers radiating from a central stalk
---
# Hitbox: central trunk blocks light
hitbox circle 1.0,1.0 0.40 z 0-1.8
# Rocky holdfast base
circle 1.0,1.0 0.55 fill #554030 0.45
circle 1.0,1.0 0.55 stroke #2a1810 width 1
# Central trunk cross-section (top of the pillar)
circle 1.0,1.0 0.18 texfill polyhaven/rock_boulder_cracked 0.75
circle 1.0,1.0 0.18 fill #d04020 0.55
circle 1.0,1.0 0.18 stroke #802010 width 2
# === Branches radiating outward (tongue-shaped polys from center) ===
# North branch
poly 0.90,0.90 1.10,0.90 1.06,0.30 1.00,0.10 0.94,0.30 fill #e05030 0.85
poly 0.90,0.90 1.10,0.90 1.06,0.30 1.00,0.10 0.94,0.30 stroke #802010
# NE branch
