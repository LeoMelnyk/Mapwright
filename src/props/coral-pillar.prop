circle 1.00,0.20 0.04 fill #ffb080 0.9
circle 1.65,0.38 0.035 fill #ffa070 0.85
circle 1.85,1.00 0.04 fill #ffb080 0.9
circle 1.62,1.72 0.035 fill #ffa070 0.85
