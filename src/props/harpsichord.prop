line 1.42,1.44 1.42,1.74 stroke #8a7858 0.6
line 1.56,1.44 1.56,1.74 stroke #8a7858 0.6
line 1.70,1.44 1.70,1.74 stroke #8a7858 0.6
line 1.84,1.44 1.84,1.74 stroke #8a7858 0.6
line 1.98,1.44 1.98,1.74 stroke #8a7858 0.6
line 2.12,1.44 2.12,1.74 stroke #8a7858 0.6
line 2.26,1.44 2.26,1.74 stroke #8a7858 0.6
line 2.40,1.44 2.40,1.74 stroke #8a7858 0.6
line 2.54,1.44 2.54,1.74 stroke #8a7858 0.6
line 2.68,1.44 2.68,1.74 stroke #8a7858 0.6

# Sharps (black keys — shorter, grouped 2 and 3)
