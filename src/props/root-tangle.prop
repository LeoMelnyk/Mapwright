name: Root Tangle
category: Terrain
footprint: 2x2
facing: no
shadow: no
blocks_light: no
placement: center
room_types: mushroom-cavern, cave-living, druid-grove, forest, ruin, underdark
typical_count: few
clusters_with: roots, moss-patch, mushroom, decaying-log
notes: Mass of tree roots hanging from ceiling or crossing overhead — strings of thick tendrils draped across the cell
---
# Soft ground-shadow wash beneath the hanging mass
ellipse 1.0,1.0 0.85,0.75 fill #1a0f00 0.20
ellipse 1.0,1.0 0.65,0.55 fill #1a0f00 0.15

# Central thickest root mass (knotted cluster)
circle 1.00,0.95 0.18 texfill polyhaven/bark_brown_02 0.85
circle 1.00,0.95 0.18 fill #3a1f00 0.45
circle 1.00,0.95 0.18 stroke #1a1008 width 2
circle 1.00,0.95 0.12 fill #4a2800 0.85
circle 1.00,0.95 0.06 fill #6b4e2e 0.7

# Major thick roots draping across cell (thick bezier tendrils)
bezier 1.00,0.95 0.72,0.66 0.44,0.38 0.20,0.16 stroke #4a2800 width 8
bezier 1.00,0.95 0.72,0.66 0.44,0.38 0.20,0.16 stroke #1a1008 width 2
