# === HITBOX ===
hitbox ellipse 0.5,0.52 0.30,0.24 z 0-0.3

# Body curl (oval silhouette — grey tabby)
ellipse 0.5,0.52 0.30,0.24 fill #6a5a4a 0.95
ellipse 0.5,0.52 0.30,0.24 stroke #2a2218
# Tabby stripes across back
bezier 0.24,0.48 0.34,0.40 0.48,0.42 0.60,0.46 stroke #3a3020 0.7 width 1
bezier 0.26,0.58 0.38,0.52 0.52,0.54 0.66,0.56 stroke #3a3020 0.6 width 1
bezier 0.30,0.66 0.44,0.62 0.56,0.64 0.68,0.66 stroke #3a3020 0.5 width 1
# Lighter belly/chest band
ellipse 0.52,0.58 0.16,0.08 fill #8a7a68 0.6
# Head tucked in (small circle toward belly)
circle 0.34,0.54 0.12 fill #6a5a4a 0.95
circle 0.34,0.54 0.12 stroke #2a2218
# Ear triangles
poly 0.26,0.46 0.30,0.40 0.32,0.46 fill #4a3a2a 0.9
poly 0.26,0.46 0.30,0.40 0.32,0.46 stroke #2a2218
