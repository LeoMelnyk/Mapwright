bezier 0.76,0.52 0.82,0.40 0.72,0.34 0.58,0.34 stroke #2a2218 width 1
# Tail stripes
line 0.74,0.46 0.78,0.44 stroke #3a3020 0.7
line 0.78,0.40 0.82,0.38 stroke #3a3020 0.7
# Tail tip (darker)
circle 0.58,0.34 0.035 fill #3a2a1a 0.9
