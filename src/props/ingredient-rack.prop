circle 0.76,0.66 0.08 stroke #a09070
circle 0.76,0.66 0.04 fill #8b6914 0.70

# Loose herb sprigs — dark green scatter
ellipse 1.06,0.65 0.10,0.06 fill #4a6a32 0.65
ellipse 1.10,0.62 0.08,0.05 fill #5a7a3e 0.55

