name: Ingredient Rack
category: Alchemy
footprint: 1x2
facing: yes
shadow: no
blocks_light: yes
height: 6
placement: wall
room_types: alchemist-lab, kitchen, wizard-sanctum
typical_count: few
clusters_with: alchemy-bench, spice-shelf
notes: Supply storage; line walls near workbenches
---
# === HITBOX ===
hitbox rect 0.04,0.04 1.92,0.92 z 0-6

# footprint 1x2: x range 0-2, y range 0-1
# Top-down: open wooden rack frame with raw ingredients visible inside
# Two side rails + cross-brace form the frame; contents sit between rails

# Shadow beneath the rack (ground level)
rect 0.12,0.08 1.76,0.84 fill #000000 0.08

# Left side rail (weathered plank, runs wall-to-room)
rect 0.04,0.04 0.14,0.92 texfill polyhaven/weathered_planks 0.80
rect 0.04,0.04 0.14,0.92 stroke #4a2800

# Right side rail
rect 1.82,0.04 0.14,0.92 texfill polyhaven/weathered_planks 0.80
rect 1.82,0.04 0.14,0.92 stroke #4a2800

# Cross-brace near wall (north)
rect 0.04,0.06 1.92,0.10 texfill polyhaven/weathered_planks 0.80
rect 0.04,0.06 1.92,0.10 stroke #4a2800

# Front cross-brace (south, lip of rack)
rect 0.04,0.86 1.92,0.10 texfill polyhaven/weathered_planks 0.75
rect 0.04,0.86 1.92,0.10 stroke #4a2800

# --- Contents on the rack ---

# Cloth bag 1 — cream, tied with string (left side)
ellipse 0.38,0.35 0.12,0.10 fill #d4c4a8 0.85
ellipse 0.38,0.35 0.12,0.10 stroke #8b7355
circle 0.38,0.28 0.03 fill #c8b898 0.70

# Dried herb bundle — sage green cluster
ellipse 0.70,0.38 0.14,0.09 fill #6b7a4a 0.75
ellipse 0.70,0.38 0.14,0.09 stroke #3d4a28
# Twine binding
line 0.62,0.38 0.78,0.38 stroke #8b7355

# Small ceramic crock — terracotta with lid
circle 1.00,0.36 0.10 fill #b5704a 0.80
circle 1.00,0.36 0.10 stroke #7a3d22
circle 1.00,0.36 0.06 fill #c48860 0.60

# Cloth bag 2 — darker, burlap-like
ellipse 1.30,0.34 0.11,0.09 fill #8b7355 0.80
ellipse 1.30,0.34 0.11,0.09 stroke #5c3a1e
circle 1.30,0.27 0.03 fill #6b4e2e 0.65

# Dried herb bundle 2 — brownish-green, smaller
ellipse 1.60,0.36 0.11,0.08 fill #5a6b3a 0.70
ellipse 1.60,0.36 0.11,0.08 stroke #3a4a1e
line 1.53,0.36 1.67,0.36 stroke #8b7355

