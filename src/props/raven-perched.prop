line 0.56,0.28 0.56,0.42 stroke #1a1a24 width 1

# === Body (larger, more robust than crow) ===
ellipse 0.50,0.54 0.20,0.22 fill #050204 0.98
ellipse 0.50,0.54 0.20,0.22 stroke #000000

# === Folded wings (wider — primaries peek south past body) ===
