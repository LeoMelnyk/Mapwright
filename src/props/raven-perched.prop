line 0.70,0.60 0.72,0.66 stroke #1a1a24 width 1
line 0.64,0.66 0.64,0.72 stroke #1a1a24 width 1

# === Hackle feathers around neck (ruffled — raven signature) ===
line 0.42,0.66 0.40,0.72 stroke #1a1a24 width 1
line 0.48,0.68 0.46,0.74 stroke #1a1a24 width 1
line 0.54,0.68 0.56,0.74 stroke #1a1a24 width 1
line 0.60,0.66 0.62,0.72 stroke #1a1a24 width 1

# === Head (south — prominent, held forward) ===
