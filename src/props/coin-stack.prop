# Top silver coin
circle 0.60,0.56 0.08 fill #cccccc 0.95
circle 0.60,0.56 0.08 stroke #555555
circle 0.60,0.56 0.018 fill #555555 0.8
# Small stack 3 (copper, very short)
ellipse 0.76,0.72 0.06 fill #a05828 0.95
ellipse 0.76,0.72 0.06,0.03 stroke #5a2810
ellipse 0.76,0.68 0.06,0.03 fill #b06030 0.95
