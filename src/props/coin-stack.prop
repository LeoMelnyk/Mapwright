# === HITBOX ===
selection rect 0.30,0.32 0.40,0.42

# Shadow base beneath stack
ellipse 0.5,0.74 0.20,0.06 fill #1a1008 0.4
# Stack 1 (gold, tallest — center-left)
# Bottom coin
