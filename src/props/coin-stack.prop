name: Coin Stack
category: Treasure
footprint: 1x1
facing: no
shadow: yes
blocks_light: no
height: 0.3
placement: floor
room_types: counting-house, gambling-den, thieves-guild-hideout, shop-jeweler, treasure-vault, vault
