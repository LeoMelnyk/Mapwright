circle 0.36,0.44 0.09 fill #daa520 0.95
circle 0.36,0.44 0.09 stroke #5a3a00
circle 0.36,0.44 0.06 stroke #8b6914 0.6 width 1
circle 0.36,0.44 0.018 fill #5a3a00 0.8
# Stack 2 (silver, shorter — right)
ellipse 0.60,0.70 0.08,0.04 fill #888888 0.95
