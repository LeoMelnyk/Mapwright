ellipse 0.36,0.58 0.09,0.04 fill #daa520 0.95
ellipse 0.36,0.58 0.09,0.04 stroke #5a3a00
ellipse 0.36,0.52 0.09,0.04 fill #daa520 0.95
ellipse 0.36,0.52 0.09,0.04 stroke #5a3a00
ellipse 0.36,0.46 0.09,0.04 fill #e8b820 0.95
ellipse 0.36,0.46 0.09,0.04 stroke #5a3a00
