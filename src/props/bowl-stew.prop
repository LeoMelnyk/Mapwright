name: Bowl of Stew
category: Food
footprint: 1x1
facing: no
shadow: yes
blocks_light: no
height: 0.2
placement: floor
room_types: inn-common-room, tavern-common, farmhouse-common, peasant-hovel, hermit-cell
typical_count: few
