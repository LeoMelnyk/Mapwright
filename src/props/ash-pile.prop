name: Ash Pile
category: Clutter
footprint: 1x1
facing: no
shadow: no
blocks_light: no
height: 0.2
placement: floor
room_types: cave-bandit-camp, charcoal-burner-camp, elemental-fire-node, forge, hearth, shrine, foundry-great, ruined-watchtower
