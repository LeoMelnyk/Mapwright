poly 0.66,0.58 0.76,0.52 0.74,0.44 0.66,0.48 stroke #120818 width 1

# Four fingers (tapering north)
poly 0.36,0.45 0.42,0.45 0.43,0.20 0.38,0.20 fill #2a1a3a 0.92
poly 0.36,0.45 0.42,0.45 0.43,0.20 0.38,0.20 stroke #120818 width 1

poly 0.44,0.45 0.50,0.45 0.51,0.18 0.46,0.18 fill #2a1a3a 0.92
