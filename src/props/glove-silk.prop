poly 0.60,0.45 0.66,0.45 0.66,0.24 0.62,0.24 stroke #120818 width 1

# Silk sheen highlights (lighter streaks)
line 0.40,0.70 0.42,0.50 stroke #5a4a7a 0.45 width 1
line 0.56,0.72 0.58,0.52 stroke #5a4a7a 0.45 width 1
line 0.40,0.42 0.42,0.25 stroke #5a4a7a 0.4 width 1
line 0.54,0.42 0.56,0.22 stroke #5a4a7a 0.4 width 1

# Pearl button cluster at cuff
