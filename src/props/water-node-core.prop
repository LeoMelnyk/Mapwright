poly 2.80,1.50 2.55,1.54 2.55,1.46 stroke #80c8f0
# Diagonal crystal shards (smaller)
poly 0.45,0.45 0.70,0.60 0.60,0.70 fill #c0e8ff 0.8
poly 0.45,0.45 0.70,0.60 0.60,0.70 stroke #80c8f0
poly 2.55,0.45 2.30,0.60 2.40,0.70 fill #c0e8ff 0.8
poly 2.55,0.45 2.30,0.60 2.40,0.70 stroke #80c8f0
poly 0.45,2.55 0.70,2.40 0.60,2.30 fill #c0e8ff 0.8
poly 0.45,2.55 0.70,2.40 0.60,2.30 stroke #80c8f0
