# footprint 1x1: x range 0-1, y range 0-1
# Top-down looking UP at a ceiling grate — dark iron frame, bars, faint light filtering through

# Faint halo of light from above
circle 0.50,0.50 0.46 gradient-radial #ddeeff #000000 0.15

# Dark ceiling recess around the grate
rect 0.08,0.08 0.84,0.84 fill #0a0a0a 0.4

# Iron frame (thick outer border)
rect 0.12,0.12 0.76,0.76 stroke #444444 width 3

# Vertical bars
rect 0.26,0.12 0.04,0.76 fill #3a3a3a 0.8
rect 0.40,0.12 0.04,0.76 fill #3a3a3a 0.8
rect 0.54,0.12 0.04,0.76 fill #3a3a3a 0.8
