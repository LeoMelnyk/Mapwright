# Horizontal bars
rect 0.12,0.26 0.76,0.04 fill #3a3a3a 0.75
rect 0.12,0.54 0.76,0.04 fill #3a3a3a 0.75

# Faint lit stripes between bars (light filtering down)
rect 0.16,0.16 0.10,0.10 fill #ddeeff 0.15
rect 0.30,0.16 0.10,0.10 fill #ddeeff 0.12
rect 0.44,0.16 0.10,0.10 fill #ddeeff 0.15
rect 0.58,0.16 0.10,0.10 fill #ddeeff 0.12
rect 0.72,0.16 0.10,0.10 fill #ddeeff 0.15

rect 0.16,0.30 0.10,0.24 fill #ddeeff 0.12
rect 0.30,0.30 0.10,0.24 fill #ddeeff 0.15
rect 0.44,0.30 0.10,0.24 fill #ddeeff 0.12
rect 0.58,0.30 0.10,0.24 fill #ddeeff 0.15
rect 0.72,0.30 0.10,0.24 fill #ddeeff 0.12

rect 0.16,0.58 0.10,0.30 fill #ddeeff 0.12
rect 0.30,0.58 0.10,0.30 fill #ddeeff 0.15
rect 0.44,0.58 0.10,0.30 fill #ddeeff 0.12
rect 0.58,0.58 0.10,0.30 fill #ddeeff 0.15
rect 0.72,0.58 0.10,0.30 fill #ddeeff 0.12

# Bar highlights (catching faint overhead light)
line 0.28,0.14 0.28,0.86 stroke #666666 0.3 width 1
