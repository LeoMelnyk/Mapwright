circle 1.70,0.50 0.18 stroke #1a1408
circle 1.00,0.20 0.16 texfill polyhaven/rock_boulder_cracked 0.9
circle 1.00,0.20 0.16 stroke #1a1408

# Dark tunnel opening (faces south, descending into black)
poly 0.60,1.80 1.40,1.80 1.30,1.30 1.00,1.00 0.70,1.30 fill #0a0604 0.98
