circle 0.64,0.50 0.008 fill #c8d0a8 0.85

# Dark black mold blotches
circle 0.52,0.58 0.03 fill #1a1008 0.85
circle 0.56,0.44 0.022 fill #1a1008 0.8
circle 0.42,0.60 0.018 fill #1a1008 0.75

# === Split/burst seam in skin ===
bezier 0.40,0.46 0.48,0.48 0.56,0.48 0.62,0.50 stroke #1a0a00 0.8 width 2
# Oozing pulp
ellipse 0.50,0.52 0.05,0.02 fill #6a4018 0.8

# === Stem (withered, brown) ===
