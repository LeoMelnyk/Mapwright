# === Seepage stain halo on floor (drawn first, behind fruit) ===
ellipse 0.50,0.54 0.34,0.26 fill #3a2810 0.3
ellipse 0.48,0.58 0.20,0.14 fill #2a1808 0.4

# === Main rotten fruit body (collapsed, dark brown — was an apple) ===
ellipse 0.50,0.52 0.26,0.22 fill #4a2810 0.95
ellipse 0.50,0.52 0.26,0.22 stroke #1a0a00

# === Bruised/collapsed surface with irregular dents ===
poly 0.32,0.46 0.42,0.42 0.52,0.44 0.66,0.40 0.72,0.48 0.74,0.60 0.66,0.68 0.52,0.70 0.38,0.68 0.28,0.60 fill #3a2008 0.85

# === Lighter greenish-brown soft spots (where flesh broke down) ===
ellipse 0.40,0.48 0.08,0.06 fill #6a5028 0.75
ellipse 0.60,0.56 0.07,0.05 fill #5a4020 0.75
ellipse 0.48,0.62 0.06,0.04 fill #5a4020 0.7

# === White/green mold patches (fuzzy circles) ===
