name: Grave Mound
category: Misc
footprint: 2x3
facing: no
shadow: no
blocks_light: no
placement: floor
room_types: graveyard, crypt
typical_count: many
clusters_with: grave-marker
notes: Burial mound; place in rows with grave-markers
