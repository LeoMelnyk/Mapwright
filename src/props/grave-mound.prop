# Dirt mound
ellipse 1.5,1.2 1.23,0.7 texfill polyhaven/brown_mud 0.75
ellipse 1.5,1.2 1.23,0.7 stroke #5a4530
# Headstone
rect 1.35,0.1 0.3,0.7 texfill polyhaven/granite_tile 0.8
rect 1.35,0.1 0.3,0.7 stroke #666666
# Cross on headstone
rect 1.23,0.24 0.54,0.16 texfill polyhaven/granite_tile 0.8
rect 1.23,0.24 0.54,0.16 stroke #666666
