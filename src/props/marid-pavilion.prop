circle 2.45,2.45 0.18 fill #e0f0ff 0.9
circle 2.45,2.45 0.18 stroke #80a0c0
circle 2.45,2.45 0.10 fill #ffffff 0.85
# Cardinal pearl pillars (smaller)
circle 1.50,0.45 0.12 fill #e0f0ff 0.85
circle 1.50,0.45 0.12 stroke #80a0c0
circle 1.50,2.55 0.12 fill #e0f0ff 0.85
circle 1.50,2.55 0.12 stroke #80a0c0
