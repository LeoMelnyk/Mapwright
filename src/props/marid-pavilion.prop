# Dome footprint (central circle — outer silver ring)
circle 1.50,1.50 0.72 fill #c0e0f0 0.85
circle 1.50,1.50 0.72 stroke #4080a0 width 2
# Dome tier 2
circle 1.50,1.50 0.56 fill #d0e8f5 0.9
circle 1.50,1.50 0.56 stroke #6090b0
# Dome tier 3 (lighter)
circle 1.50,1.50 0.40 fill #e0f0ff 0.9
circle 1.50,1.50 0.40 stroke #80a0c0
# Dome apex (pearl finial)
circle 1.50,1.50 0.22 fill #ffffff 0.95
circle 1.50,1.50 0.22 stroke #80a0c0
circle 1.50,1.50 0.12 fill #e0f8ff 0.9
circle 1.50,1.50 0.06 fill #ffffff 0.95
