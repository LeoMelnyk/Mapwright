name: Desk Lamp
category: Features
footprint: 1x1
facing: no
shadow: yes
blocks_light: no
height: 0.5
placement: floor
room_types: command-room, mansion-study, library, study, office, wizard-sanctum, scriptorium, cartographers-office
typical_count: single
