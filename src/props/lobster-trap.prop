# === HITBOX ===
hitbox rect 0.08,0.06 0.84,0.72 z 0-1.5

# Dark interior visible through mesh
rect 0.13,0.10 0.74,0.68 fill #1a1208 0.7
# Wooden frame rails (weathered plank border)
rect 0.08,0.06 0.84,0.05 texfill polyhaven/weathered_planks 0.85
rect 0.08,0.06 0.84,0.05 stroke #3a1f00
rect 0.08,0.73 0.84,0.05 texfill polyhaven/weathered_planks 0.85
rect 0.08,0.73 0.84,0.05 stroke #3a1f00
