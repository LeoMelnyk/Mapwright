rect 0.08,0.11 0.05,0.62 stroke #3a1f00
rect 0.87,0.11 0.05,0.62 texfill polyhaven/weathered_planks 0.85
rect 0.87,0.11 0.05,0.62 stroke #3a1f00
# Center spine (lengthwise divider rail)
rect 0.13,0.38 0.74,0.04 texfill polyhaven/weathered_planks 0.8
rect 0.13,0.38 0.74,0.04 stroke #3a1f00
# Mesh netting — diagonal crosshatch (top half)
line 0.16,0.13 0.50,0.36 stroke #8b7355 0.4 width 1
line 0.50,0.13 0.84,0.36 stroke #8b7355 0.4 width 1
line 0.84,0.13 0.50,0.36 stroke #8b7355 0.4 width 1
line 0.50,0.13 0.16,0.36 stroke #8b7355 0.4 width 1
# Mesh netting — diagonal crosshatch (bottom half)
line 0.16,0.44 0.50,0.70 stroke #8b7355 0.4 width 1
line 0.50,0.44 0.84,0.70 stroke #8b7355 0.4 width 1
line 0.84,0.44 0.50,0.70 stroke #8b7355 0.4 width 1
line 0.50,0.44 0.16,0.70 stroke #8b7355 0.4 width 1
# Funnel entrance (dark cone in lower half)
ellipse 0.50,0.57 0.12,0.08 fill #0d0a04 0.6
ellipse 0.50,0.57 0.12,0.08 stroke #5c3a1e 0.5
# Corner lashings
circle 0.10,0.08 0.03 fill #8b7355 0.75
circle 0.90,0.08 0.03 fill #8b7355 0.75
circle 0.10,0.76 0.03 fill #8b7355 0.75
