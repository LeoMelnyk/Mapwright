ellipse 0.40,0.44 0.06,0.050 stroke #3a1408 0.7
ellipse 0.50,0.44 0.06,0.050 fill #dd6010 0.88
ellipse 0.50,0.44 0.06,0.050 stroke #3a1408 0.7
line 0.45,0.42 0.45,0.48 stroke #1a0a00 width 2
# Wing detail
circle 0.38,0.44 0.012 fill #ffcc00 0.7
circle 0.52,0.44 0.012 fill #ffcc00 0.7

# --- Butterfly 2 — blue at (1.30, 0.55) ---
